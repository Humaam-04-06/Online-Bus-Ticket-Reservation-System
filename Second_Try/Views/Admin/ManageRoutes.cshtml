@using Second_Try.Models
@{
    ViewData["Title"]      = "Manage Routes";
    ViewData["ActivePage"] = "ManageRoutes";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var routes = ViewBag.Routes as List<Second_Try.Models.Route> ?? new();
}
@section Styles {
    <link rel="stylesheet" href="~/css/admin/manage-employees.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin/manage-routes.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] is string sm) {<div class="adm-toast adm-toast-success"><i class="fa-solid fa-circle-check"></i> @sm</div>}
@if (TempData["ErrorMessage"]   is string em) {<div class="adm-toast adm-toast-error"><i class="fa-solid fa-triangle-exclamation"></i> @em</div>}

<div class="adm-manage-grid">
    <!-- Add Route Form -->
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title"><i class="fa-solid fa-route"></i> Add New Route</div>
        </div>
        <form asp-controller="Admin" asp-action="CreateRoute" method="POST">
            @Html.AntiForgeryToken()
            @{
                string[] cities = ["Karachi","Lahore","Islamabad","Peshawar","Quetta","Multan","Faisalabad","Rawalpindi","Hyderabad","Sialkot","Sukkur","Gujranwala"];
            }
            <div class="adm-form-group">
                <label class="adm-label">Origin City</label>
                <select name="Origin" class="adm-select" required>
                    <option value="">— Select —</option>
                    @foreach (var c in cities) { <option value="@c">@c</option> }
                </select>
            </div>
            <div class="adm-form-group">
                <label class="adm-label">Destination City</label>
                <select name="Destination" class="adm-select" required>
                    <option value="">— Select —</option>
                    @foreach (var c in cities) { <option value="@c">@c</option> }
                </select>
            </div>
            <div class="adm-form-group">
                <label class="adm-label">Est. Duration (hours)</label>
                <input type="number" name="EstimatedDurationHours" class="adm-input"
                       step="0.5" min="0.5" max="48" placeholder="e.g. 12.5" required />
            </div>
            <button type="submit" class="adm-btn adm-btn-primary" style="width:100%;justify-content:center;">
                <i class="fa-solid fa-plus"></i> Add Route
            </button>
        </form>
    </div>

    <!-- Routes Table -->
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title"><i class="fa-solid fa-route"></i> All Routes <span class="adm-badge adm-badge-info">@routes.Count</span></div>
        </div>
        @if (routes.Any())
        {
            <div class="adm-table-wrapper">
                <table class="adm-table">
                    <thead>
                        <tr><th>ID</th><th>Route</th><th>Duration</th><th>Prices Set</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in routes)
                        {
                            <tr>
                                <td><span class="adm-id-pill">RT-@r.Id.ToString("D3")</span></td>
                                <td>
                                    <span class="adm-route-pill">
                                        @r.Origin <i class="fa-solid fa-arrow-right" style="font-size:0.6rem;"></i> @r.Destination
                                    </span>
                                </td>
                                <td class="muted">@r.EstimatedDurationHours hrs</td>
                                <td>
                                    <span class="adm-badge adm-badge-info">@r.PriceLists.Count / 4 types</span>
                                </td>
                                <td>
                                    <span class="adm-badge @(r.IsActive ? "adm-badge-active" : "adm-badge-inactive")">
                                        @(r.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="adm-action-group">
                                        <a href="/Admin/ManagePriceList" class="adm-btn adm-btn-outline adm-btn-sm">
                                            <i class="fa-solid fa-tags"></i> Prices
                                        </a>
                                        <form asp-action="ToggleRoute" method="POST" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="adm-btn @(r.IsActive ? "adm-btn-warning" : "adm-btn-success") adm-btn-sm">
                                                <i class="fa-solid @(r.IsActive ? "fa-ban" : "fa-check")"></i>
                                                @(r.IsActive ? "Disable" : "Enable")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="adm-empty-state">
                <div class="adm-empty-icon"><i class="fa-solid fa-route"></i></div>
                <p class="adm-empty-title">No Routes Yet</p>
                <p class="adm-empty-sub">Add your first route using the form.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    const coordinates = {
        "Karachi": { lat: 24.8607, lon: 67.0011 },
        "Lahore": { lat: 31.5204, lon: 74.3587 },
        "Islamabad": { lat: 33.6844, lon: 73.0479 },
        "Peshawar": { lat: 34.0151, lon: 71.5249 },
        "Quetta": { lat: 30.1798, lon: 66.9750 },
        "Multan": { lat: 30.1575, lon: 71.5249 },
        "Faisalabad": { lat: 31.4504, lon: 73.1350 },
        "Rawalpindi": { lat: 33.5651, lon: 73.0169 },
        "Hyderabad": { lat: 25.3960, lon: 68.3772 },
        "Sialkot": { lat: 32.4972, lon: 74.5222 },
        "Sukkur": { lat: 27.7244, lon: 68.8228 },
        "Gujranwala": { lat: 32.1877, lon: 74.1945 }
    };

    const lookupTable = {
        "Karachi-Lahore": 18.5,
        "Islamabad-Lahore": 4.5,
        "Islamabad-Multan": 8.0,
        "Hyderabad-Karachi": 2.5,
        "Islamabad-Rawalpindi": 0.5,
        "Islamabad-Peshawar": 2.0,
        "Faisalabad-Lahore": 2.5
    };

    function calculateDuration(origin, dest) {
        if (!origin || !dest || origin === dest) return 0;
        
        const key = [origin, dest].sort().join("-");
        if (lookupTable[key]) return lookupTable[key];
        
        const o = coordinates[origin];
        const d = coordinates[dest];
        if (!o || !d) return 0;
        
        // Haversine distance formula
        const R = 6371; // Earth radius in km
        const dLat = (d.lat - o.lat) * Math.PI / 180;
        const dLon = (d.lon - o.lon) * Math.PI / 180;
        const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                  Math.cos(o.lat * Math.PI / 180) * Math.cos(d.lat * Math.PI / 180) *
                  Math.sin(dLon/2) * Math.sin(dLon/2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        const dist = R * c;
        
        // Apply routing factor 1.25x and speed 70 km/h
        const duration = (dist * 1.25) / 70;
        
        // Round to nearest 0.5 hours
        return Math.max(0.5, Math.round(duration * 2) / 2);
    }

    function updateDuration() {
        const origin = document.querySelector('select[name="Origin"]').value;
        const dest = document.querySelector('select[name="Destination"]').value;
        const input = document.querySelector('input[name="EstimatedDurationHours"]');
        
        if (origin && dest && origin !== dest) {
            const hours = calculateDuration(origin, dest);
            input.value = hours;
            
            // Format hours and minutes
            const h = Math.floor(hours);
            const m = Math.round((hours - h) * 60);
            let text = "";
            if (h > 0) text += `${h} hour${h > 1 ? 's' : ''}`;
            if (m > 0) text += ` ${m} minute${m > 1 ? 's' : ''}`;
            
            let hint = document.getElementById('duration-hint');
            if (!hint) {
                hint = document.createElement('span');
                hint.id = 'duration-hint';
                hint.style.fontSize = '0.78rem';
                hint.style.color = 'var(--accent-cyan)';
                hint.style.marginTop = '4px';
                hint.style.display = 'block';
                hint.style.fontWeight = '500';
                input.parentNode.appendChild(hint);
            }
            hint.textContent = `Auto-calculated: ${text} (${hours} hrs)`;
        } else {
            const hint = document.getElementById('duration-hint');
            if (hint) hint.remove();
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const originSelect = document.querySelector('select[name="Origin"]');
        const destSelect = document.querySelector('select[name="Destination"]');
        
        originSelect?.addEventListener('change', updateDuration);
        destSelect?.addEventListener('change', updateDuration);
    });
</script>
}
