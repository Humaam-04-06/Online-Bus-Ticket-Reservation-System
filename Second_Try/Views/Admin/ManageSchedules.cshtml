@using Second_Try.Models
@{
    ViewData["Title"] = "Manage Schedules";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var schedules = ViewBag.Schedules as List<BusSchedule> ?? new List<BusSchedule>();
    var routes = ViewBag.Routes as List<Route> ?? new List<Route>();
}

<div class="admin-header-row mb-4">
    <h1 class="admin-page-title"><i class="fa-solid fa-clock"></i> Manage Bus Schedules</h1>
    <button class="btn btn-primary" onclick="openModal()"><i class="fa-solid fa-plus"></i> Add New Schedule</button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Route</th>
                        <th>Bus Type</th>
                        <th>Departure</th>
                        <th>Arrival</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!schedules.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No schedules found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var s in schedules)
                        {
                            <tr>
                                <td class="fw-bold">@s.Route?.Origin &rarr; @s.Route?.Destination</td>
                                <td>
                                    <span class="badge bg-secondary">@s.BusType</span>
                                </td>
                                <td>@DateTime.Today.Add(s.DepartureTime).ToString("hh:mm tt")</td>
                                <td>@DateTime.Today.Add(s.ArrivalTime).ToString("hh:mm tt")</td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" 
                                            onclick="editSchedule(@s.Id, @s.RouteId, '@((int)s.BusType)', '@s.DepartureTime.ToString(@"hh\:mm")', '@s.ArrivalTime.ToString(@"hh\:mm")')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    
                                    <form asp-action="ToggleSchedule" asp-route-id="@s.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm @(s.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                                title="@(s.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fa-solid @(s.IsActive ? "fa-ban" : "fa-check")"></i>
                                        </button>
                                    </form>

                                    <form asp-action="DeleteSchedule" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this schedule permanently?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Upsert Modal -->
<div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Schedule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpsertSchedule" method="post">
                <div class="modal-body">
                    <input type="hidden" id="schedId" name="id" value="0" />
                    
                    <div class="mb-3">
                        <label class="form-label">Route</label>
                        <select id="routeId" name="RouteId" class="form-select" required>
                            <option value="">-- Select Route --</option>
                            @foreach (var r in routes)
                            {
                                <option value="@r.Id">@r.Origin &rarr; @r.Destination</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Bus Type</label>
                        <select id="busType" name="BusType" class="form-select" required asp-items="Html.GetEnumSelectList<BusType>()">
                            <option value="">-- Select Bus Type --</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Departure Time</label>
                            <input type="time" id="depTime" name="DepartureTime" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Arrival Time</label>
                            <input type="time" id="arrTime" name="ArrivalTime" class="form-control" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Schedule</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const schedModal = new bootstrap.Modal(document.getElementById('scheduleModal'));

        function openModal() {
            document.getElementById('modalTitle').innerText = "Add Schedule";
            document.getElementById('schedId').value = "0";
            document.getElementById('routeId').value = "";
            document.getElementById('busType').value = "";
            document.getElementById('depTime').value = "";
            document.getElementById('arrTime').value = "";
            schedModal.show();
        }

        function editSchedule(id, routeId, busType, depTime, arrTime) {
            document.getElementById('modalTitle').innerText = "Edit Schedule";
            document.getElementById('schedId').value = id;
            document.getElementById('routeId').value = routeId;
            document.getElementById('busType').value = busType;
            document.getElementById('depTime').value = depTime;
            document.getElementById('arrTime').value = arrTime;
            schedModal.show();
        }
    </script>
}
