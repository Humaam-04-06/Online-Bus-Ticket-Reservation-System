@using Second_Try.Models
@{
    ViewData["Title"] = "Manage Schedules";
    ViewData["ActivePage"] = "ManageSchedules";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var schedules = ViewBag.Schedules as List<BusSchedule> ?? new List<BusSchedule>();
    var routes = ViewBag.Routes as List<Route> ?? new List<Route>();
}

@if (TempData["SuccessMessage"] is string sm) {<div class="adm-toast adm-toast-success"><i class="fa-solid fa-circle-check"></i> @sm</div>}
@if (TempData["ErrorMessage"]   is string em) {<div class="adm-toast adm-toast-error"><i class="fa-solid fa-triangle-exclamation"></i> @em</div>}

<div class="adm-manage-grid">
    <!-- Upsert Schedule Form -->
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title" id="formTitle"><i class="fa-solid fa-clock"></i> Add New Schedule</div>
        </div>
        <form asp-action="UpsertSchedule" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="schedId" name="id" value="0" />
            
            <div class="adm-form-group">
                <label class="adm-label">Route</label>
                <select id="routeId" name="RouteId" class="adm-select" required>
                    <option value="">-- Select Route --</option>
                    @foreach (var r in routes)
                    {
                        <option value="@r.Id">@r.Origin &rarr; @r.Destination</option>
                    }
                </select>
            </div>

            <div class="adm-form-group">
                <label class="adm-label">Bus Type</label>
                <select id="busType" name="BusType" class="adm-select" required asp-items="Html.GetEnumSelectList<BusType>()">
                    <option value="">-- Select Bus Type --</option>
                </select>
            </div>

            <div class="adm-form-group">
                <label class="adm-label">Departure Time</label>
                <input type="time" id="depTime" name="DepartureTime" class="adm-input" required />
            </div>
            
            <div class="adm-form-group">
                <label class="adm-label">Arrival Time</label>
                <input type="time" id="arrTime" name="ArrivalTime" class="adm-input" required />
            </div>

            <div style="display: flex; gap: 10px; margin-top: 1rem;">
                <button type="button" class="adm-btn adm-btn-warning" onclick="resetForm()" id="cancelBtn" style="display:none; justify-content:center; flex: 1;">Cancel</button>
                <button type="submit" class="adm-btn adm-btn-primary" id="submitBtn" style="justify-content:center; flex: 2;">
                    <i class="fa-solid fa-save"></i> Save Schedule
                </button>
            </div>
        </form>
    </div>

    <!-- Schedules Table -->
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title"><i class="fa-solid fa-list"></i> All Schedules <span class="adm-badge adm-badge-info">@schedules.Count</span></div>
        </div>

        @if (!schedules.Any())
        {
            <div class="adm-empty-state">
                <div class="adm-empty-icon"><i class="fa-solid fa-clock"></i></div>
                <p class="adm-empty-title">No Schedules Found</p>
                <p class="adm-empty-sub">Create your first bus schedule using the form.</p>
            </div>
        }
        else
        {
            <div class="adm-table-wrapper">
                <table class="adm-table">
                    <thead>
                        <tr>
                            <th>Route</th>
                            <th>Bus Type</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in schedules)
                        {
                            <tr>
                                <td style="font-weight: 600; color: var(--text-light);">
                                    @s.Route?.Origin <i class="fa-solid fa-arrow-right mx-1" style="color: var(--accent-cyan); font-size: 0.8em;"></i> @s.Route?.Destination
                                </td>
                                <td>
                                    <span class="adm-badge adm-badge-info">@s.BusType</span>
                                </td>
                                <td>
                                    <div class="adm-cell-name">@DateTime.Today.Add(s.DepartureTime).ToString("hh:mm tt")</div>
                                    <div class="adm-cell-email">Arrival: @DateTime.Today.Add(s.ArrivalTime).ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    <span class="adm-badge @(s.IsActive ? "adm-badge-active" : "adm-badge-inactive")">
                                        @(s.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="adm-action-group">
                                        <button class="adm-btn adm-btn-sm adm-btn-primary" 
                                                onclick="editSchedule(@s.Id, @s.RouteId, '@((int)s.BusType)', '@s.DepartureTime.ToString(@"hh\:mm")', '@s.ArrivalTime.ToString(@"hh\:mm")')">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                        
                                        <form asp-action="ToggleSchedule" asp-route-id="@s.Id" method="post" style="display:inline;">
                                            <button type="submit" class="adm-btn adm-btn-sm @(s.IsActive ? "adm-btn-warning" : "adm-btn-success")" 
                                                    title="@(s.IsActive ? "Deactivate" : "Activate")">
                                                <i class="fa-solid @(s.IsActive ? "fa-ban" : "fa-check")"></i>
                                            </button>
                                        </form>

                                        <form asp-action="DeleteSchedule" asp-route-id="@s.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete this schedule permanently?');">
                                            <button type="submit" class="adm-btn adm-btn-sm adm-btn-danger" title="Delete">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function editSchedule(id, routeId, busType, depTime, arrTime) {
            document.getElementById('formTitle').innerHTML = '<i class="fa-solid fa-pen"></i> Edit Schedule';
            document.getElementById('schedId').value = id;
            document.getElementById('routeId').value = routeId;
            document.getElementById('busType').value = busType;
            document.getElementById('depTime').value = depTime;
            document.getElementById('arrTime').value = arrTime;
            
            document.getElementById('submitBtn').innerHTML = '<i class="fa-solid fa-check"></i> Update';
            document.getElementById('cancelBtn').style.display = 'flex';
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        
        function resetForm() {
            document.getElementById('formTitle').innerHTML = '<i class="fa-solid fa-clock"></i> Add New Schedule';
            document.getElementById('schedId').value = 0;
            document.getElementById('routeId').value = '';
            document.getElementById('busType').value = '';
            document.getElementById('depTime').value = '';
            document.getElementById('arrTime').value = '';
            
            document.getElementById('submitBtn').innerHTML = '<i class="fa-solid fa-save"></i> Save Schedule';
            document.getElementById('cancelBtn').style.display = 'none';
        }

        document.addEventListener('DOMContentLoaded', () => {
            const form = document.querySelector('form[action*="UpsertSchedule"]');
            form?.addEventListener('submit', function(e) {
                const depVal = document.getElementById('depTime').value;
                const arrVal = document.getElementById('arrTime').value;
                
                if (depVal && arrVal) {
                    const [depH, depM] = depVal.split(':').map(Number);
                    const [arrH, arrM] = arrVal.split(':').map(Number);
                    
                    let depMin = depH * 60 + depM;
                    let arrMin = arrH * 60 + arrM;
                    
                    let diff = arrMin - depMin;
                    if (diff < 0) {
                        diff += 24 * 60; // crossed midnight
                    }
                    
                    if (diff < 30) {
                        e.preventDefault();
                        Swal.fire({
                            icon: 'warning',
                            title: 'Validation Error',
                            text: 'Arrival Time must be at least 30 minutes after Departure Time.',
                            background: '#1a1f2e',
                            color: '#f8fafc',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                }
            });
        });
    </script>
}
