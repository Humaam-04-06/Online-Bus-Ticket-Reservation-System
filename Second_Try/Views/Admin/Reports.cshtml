@{
    ViewData["Title"]      = "Reports";
    ViewData["ActivePage"] = "Reports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    decimal totalRevenue     = ViewBag.TotalRevenue     ?? 0m;
    decimal revenueThisMonth = ViewBag.RevenueThisMonth ?? 0m;
    int totalBookings        = ViewBag.TotalBookings     ?? 0;
    int totalCustomers       = ViewBag.TotalCustomers    ?? 0;
    int pendingCount         = ViewBag.PendingCount      ?? 0;
    int acceptedCount        = ViewBag.AcceptedCount     ?? 0;
    int rejectedCount        = ViewBag.RejectedCount     ?? 0;
    var topRoutes            = ViewBag.TopRoutes as dynamic ?? null;
    int totalProcessed       = acceptedCount + rejectedCount;
    double acceptRate        = totalProcessed > 0 ? Math.Round((double)acceptedCount / totalProcessed * 100, 1) : 0;
}
@section Styles {
    <link rel="stylesheet" href="~/css/admin/reports.css" asp-append-version="true" />
}

<div class="adm-page-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 1.5rem;">
    <div>
        <h2 class="adm-page-heading">Reports & Analytics</h2>
        <p class="adm-page-sub">Comprehensive overview of system revenue, booking metrics, and top routes.</p>
    </div>
    <div>
        <button id="btn-download-pdf" class="adm-btn adm-btn-primary" style="height: 42px; border-radius: 8px; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 8px;"><i class="fa-solid fa-file-pdf"></i> Download PDF Report</button>
    </div>
</div>

<!-- Stats Row -->
<div class="adm-stats-grid" style="margin-bottom:1.5rem;">
    <div class="adm-stat-card">
        <div class="adm-stat-icon green"><i class="fa-solid fa-coins"></i></div>
        <div><div class="adm-stat-value" style="font-size:1.3rem;">@totalRevenue.ToString("N0")</div><div class="adm-stat-label">Total Revenue (PKR)</div></div>
    </div>
    <div class="adm-stat-card">
        <div class="adm-stat-icon cyan"><i class="fa-solid fa-calendar-check"></i></div>
        <div><div class="adm-stat-value" style="font-size:1.3rem;">@revenueThisMonth.ToString("N0")</div><div class="adm-stat-label">This Month (PKR)</div></div>
    </div>
    <div class="adm-stat-card">
        <div class="adm-stat-icon purple"><i class="fa-solid fa-ticket"></i></div>
        <div><div class="adm-stat-value">@totalBookings</div><div class="adm-stat-label">Total Tickets Issued</div></div>
    </div>
    <div class="adm-stat-card">
        <div class="adm-stat-icon navy"><i class="fa-solid fa-users"></i></div>
        <div><div class="adm-stat-value">@totalCustomers</div><div class="adm-stat-label">Registered Customers</div></div>
    </div>
</div>

<div class="rpt-grid">
    <!-- Request Breakdown -->
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title"><i class="fa-solid fa-chart-pie"></i> Request Breakdown</div>
        </div>
        <div class="rpt-breakdown">
            <div class="rpt-break-item">
                <div class="rpt-break-label">Accepted</div>
                <div class="rpt-break-bar-wrap">
                    <div class="rpt-break-bar rpt-bar-green" style="width:@(totalProcessed>0?(int)((double)acceptedCount/totalProcessed*100):0)%"></div>
                </div>
                <div class="rpt-break-val accepted">@acceptedCount</div>
            </div>
            <div class="rpt-break-item">
                <div class="rpt-break-label">Rejected</div>
                <div class="rpt-break-bar-wrap">
                    <div class="rpt-break-bar rpt-bar-red" style="width:@(totalProcessed>0?(int)((double)rejectedCount/totalProcessed*100):0)%"></div>
                </div>
                <div class="rpt-break-val rejected">@rejectedCount</div>
            </div>
            <div class="rpt-break-item">
                <div class="rpt-break-label">Pending</div>
                <div class="rpt-break-bar-wrap">
                    <div class="rpt-break-bar rpt-bar-amber" style="width:@(totalProcessed>0?Math.Min(100,(int)((double)pendingCount/Math.Max(totalProcessed,1)*100)):100)%"></div>
                </div>
                <div class="rpt-break-val pending">@pendingCount</div>
            </div>
        </div>
        <div class="rpt-accept-rate">
            <span>Acceptance Rate</span>
            <strong style="color:var(--adm-success);">@acceptRate%</strong>
        </div>
    </div>

    <!-- Top Routes -->
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title"><i class="fa-solid fa-fire"></i> Top Routes by Bookings</div>
        </div>
        @if (topRoutes != null)
        {
            int rank = 1;
            foreach (var tr in topRoutes)
            {
                <div class="rpt-route-row">
                    <div class="rpt-rank">#@rank</div>
                    <div class="rpt-route-info">
                        <div class="rpt-route-name">@tr.Route</div>
                        <div class="rpt-route-count">@tr.Count bookings</div>
                    </div>
                    <div class="rpt-route-rev">PKR @((decimal)tr.Revenue).ToString("N0")</div>
                </div>
                rank++;
            }
        }
        else
        {
            <div class="adm-empty-state">
                <p class="adm-empty-title">No Booking Data</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('btn-download-pdf')?.addEventListener('click', function() {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

        // Draw header/title block
        doc.setFillColor(26, 31, 46); // dark theme color
        doc.rect(0, 0, 210, 40, 'F');

        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(22);
        doc.text('SRC TRAVEL SYSTEM', 14, 18);
        
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(12);
        doc.setTextColor(200, 200, 200);
        doc.text('Executive Reports & Analytics Summary', 14, 25);
        doc.text('Date: ' + new Date().toLocaleDateString() + ' ' + new Date().toLocaleTimeString(), 14, 32);

        // Section 1: KPI Overview
        doc.setTextColor(26, 31, 46);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(14);
        doc.text('1. KPI Overview', 14, 52);

        const kpiHeaders = [['Metric', 'Value']];
        const kpiBody = [
            ['Total System Revenue', 'PKR ' + '@totalRevenue.ToString("N0")'],
            ['Revenue This Month', 'PKR ' + '@revenueThisMonth.ToString("N0")'],
            ['Total Tickets Issued', '@totalBookings'],
            ['Registered Customers', '@totalCustomers'],
            ['Booking Acceptance Rate', '@acceptRate%']
        ];

        doc.autoTable({
            head: kpiHeaders,
            body: kpiBody,
            startY: 56,
            theme: 'grid',
            headStyles: { fillColor: [26, 31, 46], textColor: [255, 255, 255] },
            styles: { fontSize: 10, cellPadding: 4 }
        });

        let currentY = doc.lastAutoTable.finalY + 12;

        // Section 2: Request Status Breakdown
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(14);
        doc.text('2. Request Status Breakdown', 14, currentY);

        const breakHeaders = [['Status', 'Count', 'Percentage']];
        const totalReqs = @acceptedCount + @rejectedCount + @pendingCount;
        const acceptedPct = totalReqs > 0 ? Math.round((@acceptedCount / totalReqs) * 100) : 0;
        const rejectedPct = totalReqs > 0 ? Math.round((@rejectedCount / totalReqs) * 100) : 0;
        const pendingPct = totalReqs > 0 ? Math.round((@pendingCount / totalReqs) * 100) : 0;

        const breakBody = [
            ['Accepted', '@acceptedCount', acceptedPct + '%'],
            ['Rejected', '@rejectedCount', rejectedPct + '%'],
            ['Pending', '@pendingCount', pendingPct + '%'],
            ['Total Booking Requests', totalReqs.toString(), '100%']
        ];

        doc.autoTable({
            head: breakHeaders,
            body: breakBody,
            startY: currentY + 4,
            theme: 'grid',
            headStyles: { fillColor: [26, 31, 46], textColor: [255, 255, 255] },
            styles: { fontSize: 10, cellPadding: 4 }
        });

        currentY = doc.lastAutoTable.finalY + 12;

        // Section 3: Top Routes by Volume
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(14);
        doc.text('3. Top Routes by Bookings', 14, currentY);

        const routeHeaders = [['Rank', 'Route Name', 'Booking Count', 'Revenue Contribution']];
        const routeBody = [];
        @if (topRoutes != null)
        {
            int rnk = 1;
            foreach (var tr in topRoutes)
            {
                <text>
                routeBody.push([
                    '#@rnk',
                    '@Html.Raw(tr.Route)',
                    '@tr.Count bookings',
                    'PKR @(((decimal)tr.Revenue).ToString("N0"))'
                ]);
                </text>
                rnk++;
            }
        }
        else
        {
            <text>
            routeBody.push(['-', 'No booking data available', '-', '-']);
            </text>
        }

        doc.autoTable({
            head: routeHeaders,
            body: routeBody,
            startY: currentY + 4,
            theme: 'grid',
            headStyles: { fillColor: [26, 31, 46], textColor: [255, 255, 255] },
            styles: { fontSize: 10, cellPadding: 4 }
        });

        doc.save('SRCTravel_Executive_Report.pdf');
    });
</script>
}
