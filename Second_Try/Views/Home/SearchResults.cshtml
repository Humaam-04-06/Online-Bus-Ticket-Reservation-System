@using Second_Try.Models
@model List<Second_Try.Models.BusSchedule>
@{
    ViewData["Title"] = "Search Results";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var prices = ViewBag.Prices as List<PriceList> ?? new List<PriceList>();
    string origin = ViewBag.SearchOrigin ?? "Unknown";
    string destination = ViewBag.SearchDestination ?? "Unknown";
    DateTime travelDate = ViewBag.SearchDate ?? DateTime.Today;
}

<div class="pt-32 pb-20 px-4 max-w-7xl mx-auto min-h-screen">
    
    <div class="mb-10 text-center">
        <h1 class="text-4xl md:text-5xl font-black text-light mb-4">Search Results</h1>
        <div class="inline-flex items-center gap-4 bg-secondary/50 border border-border rounded-full px-6 py-3 glass-panel">
            <span class="text-cyan font-semibold text-lg">@origin</span>
            <i class="fa-solid fa-arrow-right text-muted"></i>
            <span class="text-blue font-semibold text-lg">@destination</span>
            <span class="text-border mx-2">|</span>
            <span class="text-purple font-medium"><i class="fa-regular fa-calendar mr-2"></i>@travelDate.ToString("MMM dd, yyyy")</span>
        </div>
    </div>

    @if (ViewBag.NoResults == true || !Model.Any())
    {
        <div class="glass-panel p-10 rounded-2xl border border-border text-center max-w-2xl mx-auto">
            <div class="w-20 h-20 bg-secondary/50 rounded-full flex items-center justify-center mx-auto mb-6 text-muted text-3xl border border-border">
                <i class="fa-solid fa-bus-slash"></i>
            </div>
            <h2 class="text-2xl font-bold text-light mb-3">No Buses Found</h2>
            <p class="text-muted mb-8">We couldn't find any scheduled trips for this route on the selected date.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-cyan rounded-full px-8 py-3">Try Another Search</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var sched in Model)
            {
                var priceEntry = prices.FirstOrDefault(p => p.RouteId == sched.RouteId && p.BusType == sched.BusType);
                decimal fare = priceEntry?.FareAmount ?? 0;

                <div class="glass-panel rounded-2xl border border-border bg-secondary/20 hover:bg-secondary/40 hover:border-cyan/50 transition-all duration-300 flex flex-col group overflow-hidden">
                    
                    <div class="bg-gradient-to-r from-secondary to-primary p-4 border-b border-border flex justify-between items-center">
                        <span class="badge bg-cyan/20 text-cyan border border-cyan/30 px-3 py-1 text-xs font-bold uppercase tracking-wider">
                            <i class="fa-solid fa-star mr-1"></i> @sched.BusType Class
                        </span>
                        <span class="text-light font-bold text-lg">Rs @fare.ToString("N0")</span>
                    </div>

                    <div class="p-6 flex-grow">
                        <div class="flex justify-between items-center mb-6">
                            <div class="text-center">
                                <div class="text-3xl font-black text-light">@DateTime.Today.Add(sched.DepartureTime).ToString("hh:mm")</div>
                                <div class="text-sm font-semibold text-muted">@DateTime.Today.Add(sched.DepartureTime).ToString("tt")</div>
                            </div>
                            
                            <div class="flex-grow flex flex-col items-center px-4">
                                <div class="text-xs text-muted mb-1"><i class="fa-regular fa-clock mr-1"></i> @sched.Route?.EstimatedDurationHours.ToString("0.0") hrs</div>
                                <div class="w-full h-[2px] bg-border relative">
                                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-cyan bg-secondary rounded-full p-1 border border-border">
                                        <i class="fa-solid fa-bus text-[10px]"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="text-center">
                                <div class="text-3xl font-black text-light">@DateTime.Today.Add(sched.ArrivalTime).ToString("hh:mm")</div>
                                <div class="text-sm font-semibold text-muted">@DateTime.Today.Add(sched.ArrivalTime).ToString("tt")</div>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 border-t border-border mt-auto">
                        <a href="@Url.Action("NewRequest", "Customer", new { preselectRouteId = sched.RouteId, preselectScheduleId = sched.Id, preselectDate = travelDate.ToString("yyyy-MM-dd") })" class="w-full py-3 rounded-xl bg-primary text-cyan border border-cyan hover:bg-cyan hover:text-primary font-bold transition-colors flex items-center justify-center">
                            Book Now <i class="fa-solid fa-arrow-right ml-2"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
