@model IEnumerable<Second_Try.Models.Route>
@{
    ViewData["Title"] = "Popular Routes";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="relative min-h-screen py-24 bg-primary overflow-hidden">
    <!-- Background Accents -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-bold mb-6">
                Explore <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan to-blue">Popular Routes</span>
            </h1>
            <p class="text-muted max-w-2xl mx-auto text-lg">
                Discover our most frequently traveled destinations. Whether for business or leisure, SRCTravel gets you there comfortably.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @if (Model != null && Model.Any())
            {
                foreach (var route in Model)
                {
                    <div class="bg-secondary/40 backdrop-blur-md border border-border rounded-2xl p-6 hover:border-cyan/50 hover:shadow-[0_0_20px_rgba(6,182,212,0.15)] transition-all duration-300 group">
                        <div class="flex justify-between items-center mb-6">
                            <div class="flex-1 text-center">
                                <h3 class="text-xl font-bold text-light">@route.Origin</h3>
                            </div>
                            <div class="px-4 text-cyan/70 group-hover:text-cyan transition-colors">
                                <i class="fa-solid fa-bus-simple text-2xl group-hover:translate-x-1 transition-transform"></i>
                            </div>
                            <div class="flex-1 text-center">
                                <h3 class="text-xl font-bold text-light">@route.Destination</h3>
                            </div>
                        </div>
                        <div class="bg-primary/50 rounded-xl p-4 flex justify-between items-center border border-border/50">
                            <div class="flex items-center gap-2 text-muted">
                                <i class="fa-regular fa-clock text-cyan"></i>
                                <span>@route.EstimatedDurationHours.ToString("0.0") hrs</span>
                            </div>
                            <a href="@Url.Action("Index", "Home")#booking-section" class="text-sm font-semibold text-cyan hover:text-light transition-colors flex items-center gap-2">
                                Book Now <i class="fa-solid fa-arrow-right text-xs"></i>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full text-center py-12">
                    <div class="w-16 h-16 rounded-full bg-secondary flex items-center justify-center mx-auto mb-4 text-muted text-2xl">
                        <i class="fa-solid fa-road-circle-xmark"></i>
                    </div>
                    <h3 class="text-xl text-light font-medium mb-2">No active routes found</h3>
                    <p class="text-muted">Check back later for new destinations.</p>
                </div>
            }
        </div>

    </div>
</div>
