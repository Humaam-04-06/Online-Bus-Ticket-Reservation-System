                            <option value="">Origin City</option>
                            @if(ViewBag.Locations != null)
                            {
                                foreach(var loc in ViewBag.Locations)
                                {
                                    <option value="@loc">@loc</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="hidden md:flex items-center justify-center pb-3">
                        <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center border border-border text-cyan">
                            <i class="fa-solid fa-arrow-right-arrow-left"></i>
                        </div>
                    </div>

                    <div class="w-full">
                        <label class="block text-light text-sm font-semibold mb-2 text-left"><i class="fa-solid fa-location-dot text-blue mr-2"></i>To</label>
                        <select name="destination" class="w-full bg-primary/80 border border-border rounded-xl px-4 py-3 text-light focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-all" required>
                            <option value="">Destination City</option>
                            @if(ViewBag.Locations != null)
                            {
                                foreach(var loc in ViewBag.Locations)
                                {
                                    <option value="@loc">@loc</option>
                                }
                            }
