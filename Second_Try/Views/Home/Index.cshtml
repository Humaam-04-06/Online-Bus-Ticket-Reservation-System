@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const isMobile = window.innerWidth <= 1024;
            const isLowEnd = (navigator.hardwareConcurrency && navigator.hardwareConcurrency < 4) ||
                             (navigator.deviceMemory && navigator.deviceMemory < 4) ||
                             /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
            const shouldDisableAnimations = prefersReducedMotion || isMobile || isLowEnd;

            if (!shouldDisableAnimations && typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
                gsap.registerPlugin(ScrollTrigger);

                const sections = document.querySelectorAll('.stack-section');

                sections.forEach(section => {
                    const scaleContent = section.querySelector('.scale-on-scroll');
                    if (scaleContent) {
                        gsap.to(scaleContent, {
                            opacity: 1,
                            scale: 1,
                            ease: "none",
                            force3D: true, // Offload to GPU
                            scrollTrigger: {
                                trigger: section,
                                start: "top 95%",
                                end: "top 15%",
                                scrub: 0.5
                            }
                        });
                    }
                });
            } else {
                // If low-performance device, directly display elements statically
                document.querySelectorAll('.scale-on-scroll').forEach(el => {
                    el.style.opacity = '1';
                    el.style.transform = 'scale(1)';
                });
            }

            // Premium Image and Text Slider Logic
            const heroSlides = [
                {
                    heading: 'Redefining Your <br /><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#00d1ff] via-[#2e5bff] to-[#a855f7] pb-2 inline-block drop-shadow-[0_0_15px_rgba(0,209,255,0.4)]">Travel Experience</span>',
                    subtext: 'Book your journey seamlessly. With our premium modern platform, discovering routes and tracking buses is faster and easier than ever before.'
                },
                {
                    heading: 'Journey Into The <br /><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#00f2fe] via-[#4facfe] to-[#00d1ff] pb-2 inline-block drop-shadow-[0_0_15px_rgba(0,209,255,0.4)]">Extraordinary</span>',
                    subtext: 'Explore breathtaking destinations and create unforgettable memories with our ultra-comfortable, secure long-distance coaches.'
                },
                {
                    heading: 'Modern Fleet, <br /><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#a855f7] via-[#2e5bff] to-[#00d1ff] pb-2 inline-block drop-shadow-[0_0_15px_rgba(168,85,247,0.4)]">Premium Comfort</span>',
                    subtext: 'Travel in style with high-speed Wi-Fi, fully reclining seats, climate control, and on-board power outlets on every single route.'
                },
                {
                    heading: 'Connecting Cities <br /><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#00d1ff] via-[#2e5bff] to-[#a855f7] pb-2 inline-block drop-shadow-[0_0_15px_rgba(0,209,255,0.4)]">Seamlessly</span>',
                    subtext: 'Navigate the country\'s most popular intercity routes with reliable schedules, prompt departures, and live tracking every mile of the way.'
                },
                {
                    heading: 'First-Class Travel, <br /><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#00f2fe] via-[#2e5bff] to-[#a855f7] pb-2 inline-block drop-shadow-[0_0_15px_rgba(0,209,255,0.4)]">Every Seat</span>',
                    subtext: 'Join SRC Elite to unlock double rewards, complimentary terminal lounge access, and exclusive discounts for your premium commute.'
                }
            ];

            const slideItems = document.querySelectorAll('.bg-slide-item');
            const heroHeading = document.getElementById('hero-heading');
            const heroSubtext = document.getElementById('hero-subtext');
            
            let currentSlideIndex = 0;
            const slideDuration = 6000; // 6 seconds per slide

            function changeSlide() {
                const nextSlideIndex = (currentSlideIndex + 1) % heroSlides.length;

                if (slideItems.length > currentSlideIndex) {
                    slideItems[currentSlideIndex].classList.remove('active');
                }
                if (slideItems.length > nextSlideIndex) {
                    slideItems[nextSlideIndex].classList.add('active');
                }

                if (heroHeading && heroSubtext) {
                    heroHeading.classList.add('hero-text-hidden');
                    heroSubtext.classList.add('hero-text-hidden');

                    setTimeout(() => {
                        heroHeading.innerHTML = heroSlides[nextSlideIndex].heading;
                        heroSubtext.textContent = heroSlides[nextSlideIndex].subtext;

                        heroHeading.classList.remove('hero-text-hidden');
                        heroSubtext.classList.remove('hero-text-hidden');
                    }, 500);
                }

                currentSlideIndex = nextSlideIndex;
            }

            if (slideItems.length > 0) {
                slideItems[0].classList.add('active');
            }

            const isVerySmallMobile = window.innerWidth <= 640;
            if (!shouldDisableAnimations && !isVerySmallMobile && slideItems.length > 1) {
                setInterval(changeSlide, slideDuration);
            }
        });
    </script>
}
