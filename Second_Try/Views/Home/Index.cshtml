@section Scripts {
    <!-- GSAP Core and ScrollTrigger -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            gsap.registerPlugin(ScrollTrigger);

            const sections = document.querySelectorAll('.stack-section');

            sections.forEach(section => {
                const scaleContent = section.querySelector('.scale-on-scroll');
                if (scaleContent) {
                    gsap.to(scaleContent, {
                        opacity: 1,
                        scale: 1,
                        ease: "none",
                        force3D: true, // Offload to GPU
                        scrollTrigger: {
                            trigger: section,
                            start: "top 95%", // Start scaling when the top of the section enters the bottom of the screen
                            end: "top 15%",   // Finish scaling right before it hits its sticky position at the top
                            scrub: 0.5        // 0.5 second of smoothing for the scrub effect (reduced from 1s for better performance)
                        }
                    });
                }
            });
        });
    </script>
}
