                    <button type="submit" class="w-full md:w-auto px-8 py-3 rounded-xl bg-gradient-to-r from-cyan to-blue text-primary font-bold text-lg shadow-[0_0_15px_var(--accent-blue)] hover:shadow-[0_0_25px_var(--accent-cyan)] hover:-translate-y-1 transition-all duration-300 h-[50px] flex items-center justify-center">
