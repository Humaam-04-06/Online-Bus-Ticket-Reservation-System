@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    /* Premium Background Image Slider style */
    .bg-slide-item {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transform: scale(1.03);
        transition: opacity 1.8s cubic-bezier(0.4, 0, 0.2, 1), transform 6s cubic-bezier(0.1, 0.8, 0.2, 1);
        will-change: opacity, transform;
        z-index: 0;
    }
    .bg-slide-item.active {
        opacity: 1;
        transform: scale(1);
    }
    
    /* Hero Text Slide-Up & Fade Transition */
    .hero-text-transition {
        transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        will-change: opacity, transform;
        opacity: 1;
        transform: translateY(0);
    }
    .hero-text-transition.hero-text-hidden {
        opacity: 0;
        transform: translateY(20px);
    }

    /* Override layout padding-top for a full-bleed immersive hero slider */
    main {
        padding-top: 0 !important;
    }

    /* Sticky Stacking wrapper adjustments */
    .stack-container {
        position: relative;
        width: 100%;
    }
    .stack-section {
        position: sticky;
        top: 0;
        width: 100%;
        min-height: 100vh; 
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    /* Hide scrollbar for tracks */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Scale-Up on Scroll Effect (Initial state for GSAP) */
    .scale-on-scroll {
        opacity: 0;
        transform: scale(0.6);
        will-change: transform, opacity;
    }

    /* ── MOBILE RESPONSIVENESS ───────────────────────────────── */
    @@media (max-width: 1024px) {
        /* On tablets & phones, disable the sticky stacking effect.
           Each section becomes a normal block that scrolls in sequence. */
        .stack-section {
            position: relative;
            top: auto;
            min-height: auto;
            padding: 5rem 0;
        }
        /* Disable GSAP scale animation on mobile for performance */
        .scale-on-scroll {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width: 640px) {
        .stack-section {
            padding: 2rem 0;
        }
        /* Fix hero heading on small phones */
        h1.text-5xl { font-size: 2.25rem; }
        /* Stat card grids collapse to single column */
        .cp-stats-grid {
            grid-template-columns: 1fr !important;
        }
        
        /* ── MOBILE PERFORMANCE: Disable BG Slider ── */
        .bg-slide-item {
            transition: none !important;
            transform: none !important;
            opacity: 0 !important;
        }
        .bg-slide-item:nth-child(1) {
            opacity: 1 !important; /* Only show the first image statically */
        }
    }

    /* ── REDUCED MOTION FALLBACK ─────────────────────────────── */
    @@media (prefers-reduced-motion: reduce) {
        .bg-slide-item { transition: none !important; transform: none !important; opacity: 0 !important; }
        .bg-slide-item:nth-child(1) { opacity: 1 !important; }
        .scale-on-scroll {
            opacity: 1 !important;
            transform: scale(1) !important;
            transition: none !important;
        }
    }
</style>

<div class="stack-container">
    
    <!-- Section 1: Hero Section (z-0) - STICKY STACK -->
    <div class="stack-section z-[0] bg-primary border-b border-border">
        <!-- Image Slider Background -->
        <div class="absolute inset-0 z-0 overflow-hidden">
            <div id="hero-bg-slides" class="absolute inset-0 z-0">
                <div class="bg-slide-item" style="background-image: url('https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=60&w=1200&auto=format&fit=crop');"></div>
                <div class="bg-slide-item" style="background-image: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=60&w=1200&auto=format&fit=crop');"></div>
                <div class="bg-slide-item" style="background-image: url('https://images.unsplash.com/photo-1570125909232-eb263c188f7e?q=60&w=1200&auto=format&fit=crop');"></div>
                <div class="bg-slide-item" style="background-image: url('https://images.unsplash.com/photo-1494515843206-f3117d3f51b7?q=60&w=1200&auto=format&fit=crop');"></div>
                <div class="bg-slide-item" style="background-image: url('https://images.unsplash.com/photo-1515162816999-a0c47dc192f7?q=60&w=1200&auto=format&fit=crop');"></div>
            </div>
            <!-- Global Dark Overlay with custom opacity gradient to match premium styling -->
            <div class="absolute inset-0 bg-gradient-to-b from-[#02040a]/75 to-[#02040a]/98 z-10 pointer-events-none"></div>
        </div>
        
        <!-- Premium Glow Effects -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-cyan/15 rounded-full blur-[120px] pointer-events-none z-0"></div>
        <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-purple/10 rounded-full blur-[100px] pointer-events-none z-0"></div>
        
        <div class="text-center z-10 px-4 max-w-5xl mx-auto w-full py-12 md:py-20">
            <!-- Status Pill -->
            <div class="inline-flex items-center gap-3 px-4 py-2 md:px-5 md:py-2.5 rounded-full border border-border bg-secondary/40 backdrop-blur-md mb-8 shadow-lg">
                <span class="relative flex h-3 w-3">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-3 w-3 bg-cyan"></span>
                </span>
                <span class="text-xs md:text-sm font-semibold tracking-wide text-white">Next-Gen Booking Engine</span>
            </div>
            
            <!-- Main Heading -->
            <h1 id="hero-heading" class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter mb-6 leading-tight drop-shadow-2xl text-white hero-text-transition">
                Redefining Your <br />
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#00d1ff] via-[#2e5bff] to-[#a855f7] pb-2 inline-block drop-shadow-[0_0_15px_rgba(0,209,255,0.4)]">Travel Experience</span>
            </h1>
            
            <!-- Subtitle -->
            <p id="hero-subtext" class="text-slate-100 text-lg md:text-2xl mx-auto mb-12 leading-relaxed max-w-3xl font-light hero-text-transition">
                Book your journey seamlessly. With our premium modern platform, discovering routes and tracking buses is faster and easier than ever before.
            </p>
            
            <!-- Search Engine Panel -->
            <div class="glass-panel p-4 md:p-6 rounded-2xl border border-cyan/30 bg-secondary/40 backdrop-blur-xl shadow-2xl max-w-4xl mx-auto mb-8 relative z-20">
                <form action="/Home/SearchBuses" method="get" class="flex flex-col md:flex-row gap-4 md:items-end">
                    <div class="w-full">
                        <label class="block text-slate-100 text-sm font-semibold mb-2 text-left"><i class="fa-solid fa-location-dot text-cyan mr-2"></i>From</label>
                        <select name="origin" class="w-full bg-primary/80 border border-border rounded-xl px-4 py-3 text-light focus:outline-none focus:border-cyan focus:ring-1 focus:ring-cyan transition-all" required>
                            <option value="">Origin City</option>
                            @if(ViewBag.Locations != null)
                            {
                                foreach(var loc in ViewBag.Locations)
                                {
                                    <option value="@loc">@loc</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="hidden md:flex items-center justify-center pb-3">
                        <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center border border-border text-cyan">
                            <i class="fa-solid fa-arrow-right-arrow-left"></i>
                        </div>
                    </div>

                    <div class="w-full">
                        <label class="block text-slate-100 text-sm font-semibold mb-2 text-left"><i class="fa-solid fa-location-dot text-blue mr-2"></i>To</label>
                        <select name="destination" class="w-full bg-primary/80 border border-border rounded-xl px-4 py-3 text-light focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-all" required>
                            <option value="">Destination City</option>
                            @if(ViewBag.Locations != null)
                            {
                                foreach(var loc in ViewBag.Locations)
                                {
                                    <option value="@loc">@loc</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="w-full">
                        <label class="block text-slate-100 text-sm font-semibold mb-2 text-left"><i class="fa-regular fa-calendar text-purple mr-2"></i>Date</label>
                        <input type="date" name="travelDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="w-full bg-white border border-border rounded-xl px-4 py-3 text-[#1F2937] focus:outline-none focus:border-purple focus:ring-1 focus:ring-purple transition-all" required style="color-scheme: light;" />
                    </div>

                    <button type="submit" class="w-full md:w-auto px-8 py-3 rounded-xl bg-gradient-to-r from-cyan to-blue text-primary font-bold text-lg shadow-[0_0_15px_var(--accent-blue)] hover:shadow-[0_0_25px_var(--accent-cyan)] hover:-translate-y-1 transition-all duration-300 h-[50px] flex items-center justify-center">
                        <i class="fa-solid fa-search mr-2"></i> Search
                    </button>
                </form>
            </div>

            <div class="flex justify-center">
                <a href="@Url.Action("Login", "Customer")" class="inline-flex px-8 py-3 rounded-full glass-panel border border-border text-white font-medium hover:border-cyan hover:bg-secondary/60 shadow-lg transition-all duration-300 items-center justify-center group z-20">
                    Go to Customer Portal 
                    <i class="fa-solid fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform text-cyan"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Section 2: The SRC Advantage (z-10) - STICKY STACK -->
    <div class="stack-section z-[10] bg-primary border-t border-border rounded-t-[2rem] md:rounded-t-[3rem] shadow-[0_-20px_50px_rgba(0,0,0,0.8)]">
