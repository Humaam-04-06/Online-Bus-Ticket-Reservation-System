@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    /* Background Image Slider Animation */
    @@keyframes bg-slider {
        0%, 16% { opacity: 1; transform: scale(1); }
        20%, 96% { opacity: 0; transform: scale(1.05); }
        100% { opacity: 1; transform: scale(1); }
    }
    .bg-slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        opacity: 0;
        animation: bg-slider 25s infinite;
        transition: transform 5s linear;
        will-change: opacity, transform;
        transform: translateZ(0); /* Force Hardware Acceleration */
    }
    .bg-slide::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(2, 4, 10, 0.75), rgba(2, 4, 10, 0.98));
    }
    .bg-slide:nth-child(1) { animation-delay: 0s; background-image: url('https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=80&w=2069&auto=format&fit=crop'); }
    .bg-slide:nth-child(2) { animation-delay: 5s; background-image: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=2021&auto=format&fit=crop'); }
    .bg-slide:nth-child(3) { animation-delay: 10s; background-image: url('https://images.unsplash.com/photo-1570125909232-eb263c188f7e?q=80&w=2071&auto=format&fit=crop'); }
    .bg-slide:nth-child(4) { animation-delay: 15s; background-image: url('https://images.unsplash.com/photo-1494515843206-f3117d3f51b7?q=80&w=2072&auto=format&fit=crop'); }
    .bg-slide:nth-child(5) { animation-delay: 20s; background-image: url('https://images.unsplash.com/photo-1515162816999-a0c47dc192f7?q=80&w=2070&auto=format&fit=crop'); }

    /* Sticky Stacking wrapper adjustments */
    .stack-container {
        position: relative;
        width: 100%;
    }
    .stack-section {
        position: sticky;
        top: 64px; /* Matches navbar height */
        width: 100%;
        min-height: calc(100vh - 64px); 
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    /* Hide scrollbar for tracks */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Scale-Up on Scroll Effect (Initial state for GSAP) */
    .scale-on-scroll {
        opacity: 0;
        transform: scale(0.6);
        will-change: transform, opacity;
    }

    /* ── MOBILE RESPONSIVENESS ───────────────────────────────── */
    @@media (max-width: 1024px) {
        /* On tablets & phones, disable the sticky stacking effect.
           Each section becomes a normal block that scrolls in sequence. */
        .stack-section {
            position: relative;
            top: auto;
            min-height: auto;
            padding: 5rem 0;
        }
        /* Disable GSAP scale animation on mobile for performance */
        .scale-on-scroll {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width: 640px) {
        .stack-section {
            padding: 4rem 0;
        }
        /* Fix hero heading on small phones */
        h1.text-5xl { font-size: 2.25rem; }
        /* Stat card grids collapse to single column */
        .cp-stats-grid {
            grid-template-columns: 1fr !important;
        }
        
        /* ── MOBILE PERFORMANCE: Disable BG Slider ── */
        .bg-slide {
            animation: none !important;
            opacity: 0;
        }
        .bg-slide:nth-child(1) {
            opacity: 1; /* Only show the first image statically */
        }
    }

    /* ── REDUCED MOTION FALLBACK ─────────────────────────────── */
    @@media (prefers-reduced-motion: reduce) {
        .bg-slide { animation: none !important; opacity: 0; }
        .bg-slide:nth-child(1) { opacity: 1; }
        .scale-on-scroll {
            opacity: 1 !important;
            transform: scale(1) !important;
            transition: none !important;
        }
    }
</style>

<div class="stack-container">
    
    <!-- Section 1: Hero Section (z-0) - STICKY STACK -->
