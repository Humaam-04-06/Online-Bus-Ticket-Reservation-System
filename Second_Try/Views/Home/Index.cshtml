            <div class="text-center mb-10 md:mb-16">
                <div class="inline-flex items-center gap-3 px-4 py-2 md:px-5 md:py-2.5 rounded-full border border-cyan/30 bg-cyan/10 mb-6 md:mb-8 shadow-lg">
                    <i class="fa-solid fa-bolt text-cyan"></i>
                    <span class="text-xs md:text-sm font-semibold tracking-wide text-cyan">Why Choose Us</span>
                </div>
                <h2 class="text-3xl md:text-6xl font-bold text-light mb-4 md:mb-6 tracking-tight">The SRC Advantage</h2>
                <p class="text-muted text-lg md:text-xl max-w-2xl mx-auto">Discover why thousands of passengers trust us for their daily commute and long-distance journeys.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                <!-- Card 1 -->
                <div class="glass-panel rounded-3xl p-6 md:p-10 border border-border bg-secondary/30 hover:bg-secondary/60 transition-all duration-300 group">
                    <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-cyan to-blue p-[2px] mb-6 md:mb-8">
                        <div class="w-full h-full bg-primary rounded-[14px] flex items-center justify-center text-cyan text-2xl md:text-3xl group-hover:scale-110 transition-transform shadow-inner">
                            <i class="fa-solid fa-bolt"></i>
                        </div>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-light mb-3 md:mb-4">Lightning Fast Booking</h3>
                    <p class="text-muted leading-relaxed text-sm md:text-base">Book your tickets in under 60 seconds with our optimized process. Say goodbye to long queues.</p>
                </div>

                <!-- Card 2 -->
                <div class="glass-panel rounded-3xl p-6 md:p-10 border border-border bg-secondary/30 hover:bg-secondary/60 transition-all duration-300 group">
                    <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-purple to-blue p-[2px] mb-6 md:mb-8">
                        <div class="w-full h-full bg-primary rounded-[14px] flex items-center justify-center text-purple text-2xl md:text-3xl group-hover:scale-110 transition-transform shadow-inner">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-light mb-3 md:mb-4">Secure & Reliable</h3>
                    <p class="text-muted leading-relaxed text-sm md:text-base">Your data and journeys are secure. We prioritize privacy with encryption and vetted operators.</p>
                </div>

                <!-- Card 3 -->
                <div class="glass-panel rounded-3xl p-6 md:p-10 border border-border bg-secondary/30 hover:bg-secondary/60 transition-all duration-300 group">
                    <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-blue to-cyan p-[2px] mb-6 md:mb-8">
                        <div class="w-full h-full bg-primary rounded-[14px] flex items-center justify-center text-blue text-2xl md:text-3xl group-hover:scale-110 transition-transform shadow-inner">
                            <i class="fa-solid fa-map-location-dot"></i>
                        </div>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-light mb-3 md:mb-4">Real-time Tracking</h3>
                    <p class="text-muted leading-relaxed text-sm md:text-base">Never miss your bus. Track your assigned bus in real-time from your customer dashboard.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 3: How It Works (z-20) - STICKY STACK -->
    <div class="stack-section z-[20] bg-[#0a0d14] shadow-[0_-20px_50px_rgba(0,0,0,0.8)] border-t border-border rounded-t-[2rem] md:rounded-t-[3rem]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24 w-full relative z-10">
            <div class="text-center mb-12 md:mb-20">
                <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight">Your Journey in 4 Simple Steps</h2>
                <p class="text-slate-300 text-sm md:text-lg max-w-2xl mx-auto">We've removed all the friction. Booking your premium travel is now incredibly effortless.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
                <!-- Connecting Line for Desktop -->
                <div class="hidden md:block absolute top-10 left-[12%] right-[12%] h-[2px] bg-gradient-to-r from-cyan via-purple to-success opacity-30 z-0"></div>

                <!-- Step 1 -->
                <div class="relative z-10 text-center group">
                    <div class="w-20 h-20 mx-auto rounded-full bg-[#0a0d14] border-2 border-cyan flex items-center justify-center text-3xl font-black text-cyan mb-6 shadow-[0_0_20px_rgba(0,209,255,0.2)] group-hover:bg-cyan group-hover:text-primary transition-all duration-300">
                        1
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Search Route</h3>
                    <p class="text-slate-300 text-sm px-4">Enter your origin, destination, and travel date to find available luxury buses.</p>
                </div>

                <!-- Step 2 -->
                <div class="relative z-10 text-center group">
                    <div class="w-20 h-20 mx-auto rounded-full bg-[#0a0d14] border-2 border-purple flex items-center justify-center text-3xl font-black text-purple mb-6 shadow-[0_0_20px_rgba(110,86,207,0.2)] group-hover:bg-purple group-hover:text-primary transition-all duration-300">
                        2
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Select Bus</h3>
                    <p class="text-slate-300 text-sm px-4">Compare fares, view amenities, and choose the perfect schedule for your trip.</p>
                </div>

                <!-- Step 3 -->
                <div class="relative z-10 text-center group">
                    <div class="w-20 h-20 mx-auto rounded-full bg-[#0a0d14] border-2 border-blue flex items-center justify-center text-3xl font-black text-blue mb-6 shadow-[0_0_20px_rgba(46,91,255,0.2)] group-hover:bg-blue group-hover:text-primary transition-all duration-300">
                        3
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Confirm Request</h3>
                    <p class="text-slate-300 text-sm px-4">Submit your booking request instantly. Our agents review and confirm in minutes.</p>
                </div>

                <!-- Step 4 -->
                <div class="relative z-10 text-center group">
                    <div class="w-20 h-20 mx-auto rounded-full bg-[#0a0d14] border-2 border-success flex items-center justify-center text-3xl font-black text-success mb-6 shadow-[0_0_20px_rgba(63,185,80,0.2)] group-hover:bg-success group-hover:text-primary transition-all duration-300">
