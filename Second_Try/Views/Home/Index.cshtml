        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24 w-full relative z-10 scale-on-scroll">
            <div class="hidden md:block absolute -left-40 top-20 w-[500px] h-[500px] bg-cyan/5 rounded-full blur-[100px] pointer-events-none"></div>
            <div class="hidden md:block absolute -right-40 bottom-20 w-[500px] h-[500px] bg-blue/5 rounded-full blur-[100px] pointer-events-none"></div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-16 items-center">
                <!-- Left: Text & Grid -->
                <div class="order-2 lg:order-1">
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-light mb-4 md:mb-6 tracking-tight">Travel in Absolute Comfort</h2>
                    <p class="text-muted text-sm md:text-xl mb-8 md:mb-12 leading-relaxed">Our modern fleet is equipped with state-of-the-art facilities to ensure your journey is relaxing, productive, and memorable.</p>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="glass-panel p-6 rounded-3xl border border-border flex flex-col gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary border border-border flex items-center justify-center text-cyan shadow-inner text-xl">
                                <i class="fa-solid fa-wifi"></i>
                            </div>
                            <h4 class="text-light font-bold">High-Speed Wi-Fi</h4>
                        </div>
                        <div class="glass-panel p-6 rounded-3xl border border-border flex flex-col gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary border border-border flex items-center justify-center text-purple shadow-inner text-xl">
                                <i class="fa-solid fa-chair"></i>
                            </div>
                            <h4 class="text-light font-bold">Reclining Seats</h4>
                        </div>
                        <div class="glass-panel p-6 rounded-3xl border border-border flex flex-col gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary border border-border flex items-center justify-center text-blue shadow-inner text-xl">
                                <i class="fa-solid fa-plug"></i>
                            </div>
                            <h4 class="text-light font-bold">Power Outlets</h4>
                        </div>
                        <div class="glass-panel p-6 rounded-3xl border border-border flex flex-col gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary border border-border flex items-center justify-center text-success shadow-inner text-xl">
                                <i class="fa-solid fa-snowflake"></i>
                            </div>
                            <h4 class="text-light font-bold">Climate Control</h4>
                        </div>
                    </div>
                </div>

                <!-- Right: Image -->
                <div class="relative rounded-[2.5rem] overflow-hidden border-2 border-border shadow-2xl glass-panel p-3 w-full aspect-square md:aspect-[4/3]">
                    <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=60&w=800&auto=format&fit=crop" alt="Premium Bus Interior" class="w-full h-full object-cover rounded-[2rem]" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-[#02040A] via-transparent to-transparent pointer-events-none rounded-[2rem]"></div>
                    <div class="absolute bottom-8 left-8 right-8 glass-panel p-6 rounded-3xl border border-border/50 backdrop-blur-xl flex justify-between items-center">
                        <div>
                            <h4 class="text-light font-bold text-xl mb-1">Luxury Coach</h4>
                            <p class="text-cyan text-sm">Available on intercity routes</p>
                        </div>
                        <div class="w-12 h-12 rounded-full bg-gradient-to-r from-cyan to-blue flex items-center justify-center text-primary text-xl">
                            <i class="fa-solid fa-star"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 5: SRC Elite Membership (z-40) - STICKY STACK -->
    <div class="stack-section z-[40] bg-[#0a0d14] shadow-[0_-20px_50px_rgba(0,0,0,0.8)] border-t border-border rounded-t-[2rem] md:rounded-t-[3rem]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24 w-full relative">
            <div class="hidden md:block absolute right-0 top-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-l from-cyan/10 to-transparent rounded-full blur-[100px] pointer-events-none"></div>

            <div class="glass-panel border border-cyan/30 rounded-3xl p-1 lg:p-2 bg-gradient-to-r from-secondary/80 to-[#0a0d14]/80 backdrop-blur-xl relative overflow-hidden group shadow-2xl">
                <div class="absolute inset-0 bg-gradient-to-r from-cyan/20 via-blue/10 to-purple/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
                
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 items-center">
                    <!-- Left: Card / Badge -->
                    <div class="lg:col-span-2 p-8 md:p-12 relative flex justify-center">
                        <div class="w-full max-w-sm aspect-[1.6/1] rounded-2xl bg-gradient-to-br from-[#1a1c29] to-[#0a0c16] border border-cyan/50 shadow-[0_0_30px_rgba(0,209,255,0.2)] relative overflow-hidden flex flex-col justify-between p-6 transform -rotate-3 hover:rotate-0 transition-transform duration-500 hover:scale-105 z-10">
                            <div class="absolute top-0 right-0 w-32 h-32 bg-cyan/20 rounded-full blur-2xl -mr-10 -mt-10"></div>
                            <div class="flex justify-between items-start">
                                <i class="fa-solid fa-crown text-3xl text-cyan drop-shadow-[0_0_10px_rgba(0,209,255,0.8)]"></i>
                                <span class="text-xs font-bold tracking-widest text-slate-400 uppercase">Elite Tier</span>
                            </div>
                            <div>
                                <div class="font-mono text-white/80 tracking-widest text-lg mb-1">•••• •••• •••• 8923</div>
                                <div class="flex justify-between items-end">
                                    <span class="font-bold text-white uppercase tracking-widest">VIP Member</span>
                                    <i class="fa-brands fa-nfc-symbol text-2xl text-cyan/70"></i>
                                </div>
                            </div>
                        </div>
                    </div>

