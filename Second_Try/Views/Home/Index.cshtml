                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Ready to Travel</h3>
                    <p class="text-slate-300 text-sm px-4">Pay at the counter on the travel day and enjoy our premium amenities.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 4: Premium Fleet Amenities (z-30) - STICKY STACK -->
