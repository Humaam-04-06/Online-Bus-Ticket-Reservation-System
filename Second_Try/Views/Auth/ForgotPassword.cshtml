@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    bool success = ViewBag.Success is bool s && s;
}

<style>
    .fp-wrapper {
        display: flex; align-items: center; justify-content: center;
        min-height: calc(100vh - 64px); padding: 2rem;
        background: var(--bg-primary);
    }
    .fp-card {
        background: var(--bg-secondary);
        border-radius: 1.5rem;
        box-shadow: 0 20px 50px rgba(92,126,143,0.15);
        padding: 2.75rem 2.25rem;
        width: 100%; max-width: 440px;
        animation: fpFade 0.4s ease;
    }
    @@keyframes fpFade {
        from { opacity:0; transform: translateY(14px); }
        to   { opacity:1; transform: translateY(0); }
    }
    .fp-icon {
        width: 64px; height: 64px; border-radius: 50%;
        background: rgba(92,126,143,0.12);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; color: var(--accent-cyan); margin: 0 auto 1.5rem;
    }
    .fp-title { font-size: 1.5rem; font-weight: 800; color: var(--text-light); text-align: center; margin: 0 0 0.5rem; }
    .fp-sub   { font-size: 0.875rem; color: var(--text-muted); text-align: center; margin: 0 0 1.75rem; line-height: 1.6; }
    .fp-input {
        width: 100%; padding: 0.75rem 1rem;
        border: 1.5px solid var(--border-color); border-radius: 0.75rem;
        background: var(--bg-primary); color: var(--text-light);
        font-size: 0.9rem; font-family: 'Inter', sans-serif;
        box-sizing: border-box; transition: border-color 0.2s;
        margin-bottom: 1rem;
    }
    .fp-input:focus { outline: none; border-color: var(--accent-cyan); box-shadow: 0 0 0 3px rgba(92,126,143,0.12); }
    .fp-btn {
        width: 100%; padding: 0.8rem;
        background: var(--accent-cyan); color: #fff;
        border: none; border-radius: 0.75rem;
        font-size: 0.95rem; font-weight: 700; cursor: pointer;
        font-family: 'Inter', sans-serif; transition: background 0.2s, transform 0.15s;
    }
    .fp-btn:hover { background: #4a6878; transform: translateY(-1px); }
    .fp-error  { background: #FEF2F2; border: 1px solid #FECACA; color: #991B1B;
                 border-radius: 0.6rem; padding: 0.7rem 1rem; font-size: 0.83rem;
                 margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .fp-success { background: #F0FDF4; border: 1px solid #BBF7D0; color: #166534;
                  border-radius: 0.75rem; padding: 1.25rem; text-align: center; }
    .fp-success i { font-size: 2rem; color: #22C55E; margin-bottom: 0.5rem; display: block; }
    .fp-back { display: block; text-align: center; margin-top: 1.25rem;
               color: var(--text-muted); font-size: 0.85rem; text-decoration: none;
               transition: color 0.2s; }
    .fp-back:hover { color: var(--accent-cyan); }
</style>

<div class="fp-wrapper">
    <div class="fp-card">
        <div class="fp-icon"><i class="fa-solid fa-lock"></i></div>
        <h1 class="fp-title">Forgot Password?</h1>

        @if (success)
        {
            <div class="fp-success">
                <i class="fa-solid fa-circle-check"></i>
                <strong>Check your inbox!</strong><br>
                <span style="font-size:0.85rem;color:#166534;">If an account exists for that email, we've sent a password reset link. It expires in 30 minutes.</span>
            </div>
        }
        else
        {
            <p class="fp-sub">Enter the email linked to your account and we'll send you a reset link.</p>

            @if (ViewBag.Error is string err)
            {
                <div class="fp-error"><i class="fa-solid fa-circle-exclamation"></i> @err</div>
            }

            <form method="post" asp-action="ForgotPassword" asp-controller="Auth">
                @Html.AntiForgeryToken()
                <input type="email" name="email" class="fp-input" placeholder="your@email.com" required autofocus />
                <button type="submit" class="fp-btn">
                    <i class="fa-solid fa-paper-plane" style="margin-right:0.4rem;"></i>Send Reset Link
                </button>
            </form>
        }

        <a href="/Auth/Login" class="fp-back">
            <i class="fa-solid fa-arrow-left" style="margin-right:0.3rem;font-size:0.75rem;"></i>Back to Login
        </a>
    </div>
</div>
