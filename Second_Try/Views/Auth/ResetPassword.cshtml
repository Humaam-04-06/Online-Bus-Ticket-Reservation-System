@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    string? token = ViewBag.Token as string;
    string? error = ViewBag.Error as string;
}

<style>
    .rp-wrapper {
        display: flex; align-items: center; justify-content: center;
        min-height: calc(100vh - 64px); padding: 2rem;
        background: var(--bg-primary);
    }
    .rp-card {
        background: var(--bg-secondary);
        border-radius: 1.5rem;
        box-shadow: 0 20px 50px rgba(92,126,143,0.15);
        padding: 2.75rem 2.25rem;
        width: 100%; max-width: 440px;
        animation: rpFade 0.4s ease;
    }
    @@keyframes rpFade {
        from { opacity:0; transform: translateY(14px); }
        to   { opacity:1; transform: translateY(0); }
    }
    .rp-icon {
        width: 64px; height: 64px; border-radius: 50%;
        background: rgba(92,126,143,0.12);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; color: var(--accent-cyan); margin: 0 auto 1.5rem;
    }
    .rp-title { font-size: 1.5rem; font-weight: 800; color: var(--text-light); text-align: center; margin: 0 0 0.5rem; }
    .rp-sub   { font-size: 0.875rem; color: var(--text-muted); text-align: center; margin: 0 0 1.75rem; line-height: 1.6; }
    .rp-label { display: block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.04em;
                text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.35rem; }
    .rp-input {
        width: 100%; padding: 0.75rem 1rem;
        border: 1.5px solid var(--border-color); border-radius: 0.75rem;
        background: var(--bg-primary); color: var(--text-light);
        font-size: 0.9rem; font-family: 'Inter', sans-serif;
        box-sizing: border-box; transition: border-color 0.2s;
        margin-bottom: 1rem;
    }
    .rp-input:focus { outline: none; border-color: var(--accent-cyan); box-shadow: 0 0 0 3px rgba(92,126,143,0.12); }
    .rp-btn {
        width: 100%; padding: 0.8rem;
        background: var(--accent-cyan); color: #fff;
        border: none; border-radius: 0.75rem;
        font-size: 0.95rem; font-weight: 700; cursor: pointer;
        font-family: 'Inter', sans-serif; transition: background 0.2s, transform 0.15s;
        margin-top: 0.25rem;
    }
    .rp-btn:hover { background: #4a6878; transform: translateY(-1px); }
    .rp-error  { background: #FEF2F2; border: 1px solid #FECACA; color: #991B1B;
                 border-radius: 0.6rem; padding: 0.7rem 1rem; font-size: 0.83rem;
                 margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
    .rp-strength { height: 4px; background: #e5e7eb; border-radius: 2px; overflow: hidden; margin-bottom: 0.25rem; }
    .rp-strength-fill { height: 100%; width: 0%; border-radius: 2px; transition: width 0.3s, background 0.3s; }
    .rp-strength-label { font-size: 0.7rem; color: var(--text-muted); margin-bottom: 0.75rem; }
    .rp-back { display: block; text-align: center; margin-top: 1.25rem;
               color: var(--text-muted); font-size: 0.85rem; text-decoration: none; transition: color 0.2s; }
    .rp-back:hover { color: var(--accent-cyan); }
</style>

<div class="rp-wrapper">
    <div class="rp-card">
        <div class="rp-icon"><i class="fa-solid fa-key"></i></div>
        <h1 class="rp-title">Set New Password</h1>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="rp-sub" style="color:var(--danger);">@error</p>
            <a href="/Auth/ForgotPassword" class="rp-btn" style="display:block;text-align:center;text-decoration:none;margin-top:0.5rem;">
                Request New Link
            </a>
        }
        else if (string.IsNullOrEmpty(token))
        {
            <p class="rp-sub">Invalid reset link. Please request a new one.</p>
            <a href="/Auth/ForgotPassword" class="rp-btn" style="display:block;text-align:center;text-decoration:none;">
                Go to Forgot Password
            </a>
        }
        else
        {
            <p class="rp-sub">Choose a strong password for your account. Minimum 8 characters.</p>

            <form method="post" asp-action="ResetPassword" asp-controller="Auth">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />

                <label class="rp-label">New Password</label>
                <input type="password" id="rp-pwd" name="newPassword" class="rp-input"
                       placeholder="Min. 8 characters" required minlength="8" />

                <div class="rp-strength">
                    <div class="rp-strength-fill" id="rp-fill"></div>
                </div>
                <p class="rp-strength-label" id="rp-slabel">Enter a password</p>

                <label class="rp-label">Confirm Password</label>
                <input type="password" id="rp-confirm" name="confirmPassword" class="rp-input"
                       placeholder="Repeat your password" required />

                <button type="submit" class="rp-btn">
                    <i class="fa-solid fa-shield-halved" style="margin-right:0.4rem;"></i>Save New Password
                </button>
            </form>
        }

        <a href="/Auth/Login" class="rp-back">
            <i class="fa-solid fa-arrow-left" style="margin-right:0.3rem;font-size:0.75rem;"></i>Back to Login
        </a>
    </div>
</div>

<script>
    const pwdInput = document.getElementById('rp-pwd');
    const fill     = document.getElementById('rp-fill');
    const label    = document.getElementById('rp-slabel');

    if (pwdInput) {
        pwdInput.addEventListener('input', () => {
            const v = pwdInput.value;
            let score = 0;
            if (v.length >= 8)  score++;
            if (/[A-Z]/.test(v)) score++;
            if (/[0-9]/.test(v)) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;

            const pct  = ['0%','25%','50%','75%','100%'][score];
            const clr  = ['','#EF4444','#F59E0B','#3B82F6','#22C55E'][score];
            const txt  = ['Enter a password','Weak','Fair','Good','Strong'][score];
            const txtC = ['var(--text-muted)','#EF4444','#F59E0B','#3B82F6','#22C55E'][score];

            fill.style.width      = pct;
            fill.style.background = clr;
            label.textContent     = txt;
            label.style.color     = txtC;
        });
    }
</script>
