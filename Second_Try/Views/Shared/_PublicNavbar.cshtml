@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Second_Try.Data
@inject ApplicationDbContext _context
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    string userEmail = User.FindFirstValue(ClaimTypes.Email) ?? "";
    string userName = User.Identity?.Name ?? "User";
    
    string? picUrl = null;
    if (isAuthenticated && !string.IsNullOrEmpty(userEmail))
    {
        var role = User.FindFirstValue(ClaimTypes.Role);
        if (role == "Customer")
        {
            var cust = _context.Customers.FirstOrDefault(c => c.Email == userEmail);
            picUrl = cust?.ProfilePictureUrl;
        }
        else
        {
            var emp = _context.Employees.FirstOrDefault(e => e.Email == userEmail);
            picUrl = emp?.ProfilePictureUrl;
        }
    }

    string dashUrl = "";
    string profileUrl = "";
    string trackUrl = "";

    if (isAuthenticated)
    {
        if (User.IsInRole("Admin"))
        {
            dashUrl = Url.Action("Dashboard", "Admin") ?? "#";
            profileUrl = Url.Action("Dashboard", "Admin") ?? "#";
            trackUrl = Url.Action("Dashboard", "Admin") ?? "#";
        }
        else if (User.IsInRole("Employee"))
        {
            dashUrl = Url.Action("Dashboard", "Employee") ?? "#";
            profileUrl = Url.Action("EmployeeProfile", "Employee") ?? "#";
            trackUrl = Url.Action("Dashboard", "Employee") ?? "#";
        }
        else
        {
            dashUrl = Url.Action("Dashboard", "Customer") ?? "#";
            profileUrl = Url.Action("Profile", "Customer") ?? "#";
            trackUrl = Url.Action("MyRequests", "Customer") ?? "#";
        }
    }
}

<style>
    /* Premium Hover & Active States for the Floating Centered Glassy Navbar */
    .nav-floating {
        position: fixed;
        left: 50%;
        transform: translate(-50%, 0);
        z-index: 50;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    .nav-floating.nav-hidden {
        transform: translate(-50%, -170%);
        opacity: 0;
        pointer-events: none;
    }
    /* Subtle glow and shadow for premium feel */
    .nav-floating {
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.15), 0 1px 1px 0 rgba(255, 255, 255, 0.05) inset;
    }
</style>

<nav class="nav-floating top-3 w-[92%] md:w-[72%] md:top-5 glass-panel border border-border/50 rounded-2xl" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            
            <!-- 1. Logo Area (Left) -->
            <div class="flex-shrink-0 flex items-center">
                <a href="@Url.Action("Index", "Home")" class="text-2xl font-bold flex items-center gap-3 group">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan to-blue flex items-center justify-center text-primary shadow-[0_0_15px_var(--accent-cyan)] group-hover:shadow-[0_0_25px_var(--accent-cyan)] transition-all duration-300">
                        <i class="fa-solid fa-bus"></i>
                    </div>
                    <span class="bg-clip-text text-transparent bg-gradient-to-r from-light to-cyan tracking-wide">SRC Travel</span>
                </a>
            </div>

            <!-- 2. Center Area (Running Name - Always Visible) -->
            <div class="hidden md:flex flex-1 justify-center px-8 overflow-hidden h-full items-center">
                <!-- Running Name Animation -->
                <div class="w-full max-w-lg overflow-hidden relative flex items-center">
                    <div class="absolute left-0 w-16 h-full bg-gradient-to-r from-[#02040A] to-transparent z-10 opacity-90"></div>
                    <span class="animate-running-text text-cyan font-bold text-[13px] tracking-widest uppercase py-2 drop-shadow-[0_0_5px_rgba(0,209,255,0.4)]">
                        <i class="fa-solid fa-bolt text-purple mr-2"></i>
                        Online Bus Ticket Reservation System • Your Journey, Our Priority
                        <i class="fa-solid fa-bolt text-purple ml-2"></i>
                    </span>
                    <div class="absolute right-0 w-16 h-full bg-gradient-to-l from-[#02040A] to-transparent z-10 opacity-90"></div>
                </div>
            </div>

            <!-- 3. Actions Area (Right) -->
            <div class="hidden md:flex items-center space-x-6">
                @if (isAuthenticated)
                {
                    <!-- Track Order Link -->
                    <a href="@Url.Action("MyRequests", "Customer")" class="text-light hover:text-cyan transition-colors flex items-center gap-2 group px-3 py-1.5 rounded-lg hover:bg-secondary/50 border border-transparent hover:border-border">
                        <i class="fa-solid fa-route text-purple group-hover:animate-bounce"></i>
                        <span class="font-medium text-sm">Track Order</span>
                    </a>
                    
                    <!-- Profile Dropdown -->
                    <div class="relative ml-2" id="profileDropdownContainer">
                        <button type="button" class="flex text-sm border-2 border-transparent rounded-full focus:outline-none focus:border-cyan transition-all" id="user-menu-button" aria-expanded="false" aria-haspopup="true" onclick="toggleDropdown()">
                            <div class="h-10 w-10 rounded-full border-2 border-border hover:border-cyan shadow-[0_0_10px_rgba(110,86,207,0.3)] transition-all" style="@(!string.IsNullOrEmpty(picUrl) ? "background:transparent;overflow:hidden;padding:0;" : "background:var(--primary);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:bold;")">
                                @if (!string.IsNullOrEmpty(picUrl))
                                {
                                    <img src="@picUrl" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" alt="avatar" />
                                }
                                else
                                {
                                    <span>@userName.Substring(0, 1).ToUpper()</span>
                                }
                            </div>
                            <span class="absolute bottom-0 right-0 block h-3 w-3 rounded-full bg-success ring-2 ring-primary"></span>
                        </button>
                        
                        <!-- Dropdown Menu -->
                        <div class="origin-top-right absolute right-0 mt-3 w-56 rounded-xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] bg-secondary/95 backdrop-blur-md border border-border divide-y divide-border hidden transform transition-all opacity-0 scale-95 z-50" id="profileDropdown" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-button" tabindex="-1">
                            <div class="px-4 py-3 bg-primary/30 rounded-t-xl">
                                <p class="text-xs text-muted font-medium">Signed in as</p>
                                <p class="text-sm font-bold text-light truncate mt-0.5">@userEmail</p>
                            </div>
                            <div class="py-1" role="none">
                                <a href="@dashUrl" class="group flex items-center px-4 py-2.5 text-sm text-muted hover:text-light hover:bg-primary/50 transition-colors" role="menuitem">
                                    <i class="fa-solid fa-table-columns w-5 mr-3 text-purple group-hover:text-cyan transition-colors"></i> Dashboard
                                </a>
                                <a href="@trackUrl" class="group flex items-center px-4 py-2.5 text-sm text-muted hover:text-light hover:bg-primary/50 transition-colors" role="menuitem">
                                    <i class="fa-solid fa-ticket w-5 mr-3 text-purple group-hover:text-cyan transition-colors"></i> My Requests
                                </a>
                                <a href="@profileUrl" class="group flex items-center px-4 py-2.5 text-sm text-muted hover:text-light hover:bg-primary/50 transition-colors" role="menuitem">
                                    <i class="fa-solid fa-gear w-5 mr-3 text-purple group-hover:text-cyan transition-colors"></i> Settings
                                </a>
                            </div>
                            <div class="py-1" role="none">
                                <a href="@Url.Action("Logout", "Auth")" class="group flex w-full items-center px-4 py-2.5 text-sm text-danger hover:bg-danger/10 transition-colors rounded-b-xl" role="menuitem">
                                    <i class="fa-solid fa-right-from-bracket w-5 mr-3 group-hover:-translate-x-1 transition-transform"></i> Sign out
                                </a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Login", "Auth")" class="text-light hover:text-cyan font-medium transition-colors text-sm">Log in</a>
                    <a href="@Url.Action("Login", "Auth")?register=true" class="relative inline-flex items-center justify-center px-5 py-2 overflow-hidden font-bold text-primary bg-gradient-to-r from-cyan to-blue rounded-lg shadow-[0_0_15px_var(--accent-blue)] hover:shadow-[0_0_25px_var(--accent-cyan)] transition-all group hover:-translate-y-0.5">
                        <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-white rounded-full group-hover:w-56 group-hover:h-56 opacity-20"></span>
                        <span class="relative flex items-center gap-2 text-sm"><i class="fa-solid fa-user-plus text-primary"></i> Sign Up</span>
                    </a>
                }
            </div>

            <!-- Mobile menu button -->
            <div class="flex items-center md:hidden">
                <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-muted hover:text-light hover:bg-secondary/50 focus:outline-none transition-colors" aria-controls="mobile-menu" aria-expanded="false" onclick="toggleMobileMenu()">
                    <span class="sr-only">Open main menu</span>
                    <i class="fa-solid fa-bars text-xl" id="menu-icon"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu as a floating dropdown matching navbar style -->
    <div class="hidden md:hidden bg-secondary/95 backdrop-blur-xl border border-border/50 shadow-2xl absolute left-0 right-0 top-[calc(100%+8px)] rounded-2xl overflow-hidden" id="mobile-menu">
        <div class="px-2 pt-2 pb-4 space-y-1">
            <div class="text-center py-3 mb-2 border-b border-border/50 bg-primary/30 mx-2 rounded-lg">
                <span class="animate-pulse text-cyan font-semibold text-xs tracking-widest uppercase">
                    Online Bus Ticket Reservation System
                </span>
            </div>
            @if (isAuthenticated)
            {
                <div class="flex items-center px-4 py-4 border-b border-border/50 mb-2 bg-primary/30 rounded-lg mx-2">
                    <div class="flex-shrink-0" style="@(!string.IsNullOrEmpty(picUrl) ? "background:transparent;overflow:hidden;padding:0;" : "background:var(--primary);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:bold;height:2.5rem;width:2.5rem;border-radius:50%;")">
                        @if (!string.IsNullOrEmpty(picUrl))
                        {
                            <img class="h-10 w-10 rounded-full object-cover border-2 border-cyan" src="@picUrl" alt="Profile">
                        }
                        else
                        {
                            <span>@userName.Substring(0, 1).ToUpper()</span>
                        }
                    </div>
                    <div class="ml-3">
                        <div class="text-base font-medium text-light">@userName</div>
                        <div class="text-sm font-medium text-cyan">@userEmail</div>
                    </div>
                </div>
                <a href="@trackUrl" class="block px-4 py-3 rounded-lg text-base font-medium text-light hover:bg-primary/50 transition-colors mx-2"><i class="fa-solid fa-route w-6 text-purple"></i> Track Order</a>
                <a href="@dashUrl" class="block px-4 py-3 rounded-lg text-base font-medium text-light hover:bg-primary/50 transition-colors mx-2"><i class="fa-solid fa-table-columns w-6 text-purple"></i> Dashboard</a>
                <a href="@profileUrl" class="block px-4 py-3 rounded-lg text-base font-medium text-light hover:bg-primary/50 transition-colors mx-2"><i class="fa-solid fa-gear w-6 text-purple"></i> Settings</a>
                <a href="@Url.Action("Logout", "Auth")" class="block mt-4 mx-2">
                    <button class="w-full text-left px-4 py-3 rounded-lg text-base font-medium text-danger hover:bg-danger/10 transition-colors"><i class="fa-solid fa-right-from-bracket w-6"></i> Sign out</button>
                </a>
            }
            else
            {
                <div class="mt-4 flex flex-col gap-3 mx-2 pb-2">
                    <a href="@Url.Action("Login", "Auth")" class="block text-center px-4 py-3 rounded-lg text-base font-medium text-light border border-border hover:bg-primary/50 transition-colors">Log in</a>
                    <a href="@Url.Action("Login", "Auth")?register=true" class="block text-center px-4 py-3 rounded-lg text-base font-medium text-primary bg-gradient-to-r from-cyan to-blue shadow-[0_0_15px_var(--accent-blue)]">Sign Up</a>
                </div>
            }
        </div>
    </div>
</nav>

<script>
    function toggleDropdown() {
        const menu = document.getElementById('profileDropdown');
        if (menu.classList.contains('hidden')) {
            menu.classList.remove('hidden');
            setTimeout(() => {
                menu.classList.remove('opacity-0', 'scale-95');
                menu.classList.add('opacity-100', 'scale-100');
            }, 10);
        } else {
            menu.classList.remove('opacity-100', 'scale-100');
            menu.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
                menu.classList.add('hidden');
            }, 150); 
        }
    }

    function toggleMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const icon = document.getElementById('menu-icon');
        if (menu.classList.contains('hidden')) {
            menu.classList.remove('hidden');
            icon.classList.remove('fa-bars');
            icon.classList.add('fa-xmark');
        } else {
            menu.classList.add('hidden');
            icon.classList.remove('fa-xmark');
            icon.classList.add('fa-bars');
        }
    }

    document.addEventListener('click', function(event) {
        const dropdownContainer = document.getElementById('profileDropdownContainer');
        const profileDropdown = document.getElementById('profileDropdown');
        if (dropdownContainer && !dropdownContainer.contains(event.target) && profileDropdown && !profileDropdown.classList.contains('hidden')) {
            toggleDropdown();
        }
    });

    let lastScrollY = window.scrollY;
    const nav = document.getElementById('navbar');
    const mobileMenu = document.getElementById('mobile-menu');

    window.addEventListener('scroll', function() {
        const currentScrollY = window.scrollY;
        
        // Hide/Show navbar based on scroll direction
        if (currentScrollY > lastScrollY && currentScrollY > 80) {
            // Scrolling down - hide navbar
            nav.classList.add('nav-hidden');
            // If mobile menu is open, close it
            if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
                toggleMobileMenu();
            }
        } else {
            // Scrolling up - show navbar
            nav.classList.remove('nav-hidden');
        }
        
        lastScrollY = currentScrollY;

        // Enhance background and border color when scrolling past top
        if (currentScrollY > 10) {
            nav.classList.add('shadow-2xl', 'border-cyan/30');
            nav.classList.remove('border-border/50');
        } else {
            nav.classList.remove('shadow-2xl', 'border-cyan/30');
            nav.classList.add('border-border/50');
        }
    });
</script>
