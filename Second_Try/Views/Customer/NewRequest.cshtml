@using Second_Try.Models
@{
    ViewData["Title"] = "Book Your Seats";
    ViewData["ActivePage"] = "NewRequest";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";

    BusType busType = ViewBag.BusType is BusType bt ? bt : BusType.Standard;
    bool isLuxury = busType == BusType.Luxury || busType == BusType.Express;
    int totalSeats = isLuxury ? 30 : 40;
    int seatsPerRow = isLuxury ? 3 : 4; // 2+1 luxury vs 2+2 standard
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer/new-request.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer/seat-map.css" asp-append-version="true" />
}

<div class="cp-shell-content">

    <!-- Page Header -->
    <div style="margin-bottom:1.5rem;">
        <h2 style="font-size:1.4rem;font-weight:800;color:var(--text-light);margin:0 0 0.25rem;">
            <i class="fa-solid fa-couch" style="color:var(--accent-cyan);margin-right:0.5rem;"></i>Select Your Seats
        </h2>
        <p style="color:var(--text-muted);font-size:0.875rem;margin:0;">
            <strong style="color:var(--text-light);">@ViewBag.PreOrigin &rarr; @ViewBag.PreDest</strong>
            &nbsp;&bull;&nbsp; @busType Class
            &nbsp;&bull;&nbsp; @(ViewBag.PreDate is string d ? DateTime.Parse(d).ToString("MMM dd, yyyy") : "")
        </p>
    </div>

    @if (ViewBag.HasActiveRequest == true)
    {
        <div class="nr-alert nr-alert-warning" style="margin-bottom:1.5rem;">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>
                <strong>You already have an active request.</strong>
                Please wait for it to be resolved before submitting a new one.
                <a href="/Customer/MyRequests" style="color:var(--accent-cyan);font-weight:600;">View My Requests &rarr;</a>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="nr-alert nr-alert-warning" style="margin-bottom:1rem;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }

    <div class="nr-grid">

        <!-- LEFT: Seat Map -->
        <div class="cp-card">
            <div class="cp-card-header">
                <div class="cp-card-title"><i class="fa-solid fa-bus"></i> Bus Seat Layout — @busType</div>
            </div>

            <div class="seat-map-wrapper">
                <div class="bus-front">
                    <div class="bus-front-icon"><i class="fa-solid fa-steering-wheel mr-2"></i> Driver</div>
                </div>

                <!-- Legend -->
                <div class="seat-legend">
                    <div class="seat-legend-item"><div class="legend-box available"></div> Available</div>
                    <div class="seat-legend-item"><div class="legend-box selected"></div> Your Selection</div>
                    <div class="seat-legend-item"><div class="legend-box booked"></div> Already Booked</div>
                </div>

                <!-- Seat Grid -->
                <div id="seatGrid" class="seat-grid @(isLuxury ? "layout-luxury" : "layout-standard")">
                    <!-- Rendered by JS -->
                </div>

                <!-- Selected seats chip strip -->
                <div class="selected-seats-strip" id="selectedStrip">
                    <span class="strip-label"><i class="fa-solid fa-check-circle mr-1"></i> Selected:</span>
                    <span class="empty-hint" id="emptyHint">Click seats above to select them.</span>
                </div>
            </div>
        </div>

        <!-- RIGHT: Booking Summary -->
        <div>
            <div class="cp-card" style="position:sticky;top:90px;">
                <div class="cp-card-header">
                    <div class="cp-card-title"><i class="fa-solid fa-receipt"></i> Booking Summary</div>
                </div>

                <form id="booking-form" asp-controller="Customer" asp-action="NewRequest" method="POST">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="BusScheduleId" value="@ViewBag.PreScheduleId" />
                    <input type="hidden" name="RouteId" value="@ViewBag.PreRouteId" />
                    <input type="hidden" name="Origin" value="@ViewBag.PreOrigin" />
                    <input type="hidden" name="Destination" value="@ViewBag.PreDest" />
                    <input type="hidden" name="TravelDate" value="@ViewBag.PreDate" />
                    <input type="hidden" name="PreferredBusType" value="@((int)busType)" />
                    <input type="hidden" name="NumberOfSeats" id="hiddenSeatCount" value="0" />
                    <input type="hidden" name="SelectedSeatNumbers" id="hiddenSeatNumbers" value="" />

                    <div style="padding:1.25rem;">
                        <!-- Trip Info -->
                        <div style="background:var(--bg-primary);border-radius:10px;padding:0.9rem;margin-bottom:1rem;border:1px solid var(--border-color);">
                            <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;">
                                <span style="color:var(--text-muted);font-size:0.8rem;">From</span>
                                <span style="color:var(--text-light);font-weight:700;">@ViewBag.PreOrigin</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;">
                                <span style="color:var(--text-muted);font-size:0.8rem;">To</span>
                                <span style="color:var(--text-light);font-weight:700;">@ViewBag.PreDest</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;">
                                <span style="color:var(--text-muted);font-size:0.8rem;">Date</span>
                                <span style="color:var(--text-light);font-weight:700;">@(ViewBag.PreDate is string pd ? DateTime.Parse(pd).ToString("MMM dd, yyyy") : "")</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;">
                                <span style="color:var(--text-muted);font-size:0.8rem;">Class</span>
                                <span style="color:var(--accent-cyan);font-weight:700;">@busType</span>
                            </div>
                        </div>

                        <!-- Live seat count -->
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                            <span style="color:var(--text-muted);font-size:0.85rem;">Seats Selected</span>
                            <span id="seatCount" style="color:var(--accent-cyan);font-size:1.25rem;font-weight:900;">0</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                            <span style="color:var(--text-muted);font-size:0.85rem;">Seat Numbers</span>
                            <span id="seatNumbers" style="color:var(--text-light);font-size:0.8rem;font-weight:600;">—</span>
                        </div>

                        <div style="border-top:1px solid var(--border-color);padding-top:0.75rem;margin-bottom:1rem;">
                            <p style="font-size:0.75rem;color:var(--text-muted);margin:0;line-height:1.6;">
                                <i class="fa-solid fa-info-circle" style="color:var(--accent-cyan);margin-right:0.35rem;"></i>
                                Your request will be reviewed by an employee. You will receive a notification once it is accepted or rejected.
                            </p>
                        </div>

                        <button type="submit" id="submitBtn" disabled
                            style="width:100%;padding:0.9rem;border-radius:10px;border:none;background:var(--accent-cyan);color:#000;font-size:0.95rem;font-weight:800;cursor:not-allowed;opacity:0.5;transition:all 0.2s;">
                            <i class="fa-solid fa-paper-plane mr-2"></i> Submit Request
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function() {
    const scheduleId = @(ViewBag.PreScheduleId ?? 0);
    const travelDate = '@(ViewBag.PreDate ?? DateTime.Today.ToString("yyyy-MM-dd"))';
    const isLuxury   = @(isLuxury ? "true" : "false");
    const totalSeats = @totalSeats;
    const maxSelect  = totalSeats;

    let selected = new Set();
    let booked   = new Set();

    // ── Generate seat labels ───────────────────────────────
    function buildSeatLabel(rowNum, col) {
        const cols = isLuxury ? ['A','B','C'] : ['A','B','C','D'];
        return rowNum + cols[col];
    }

    // ── Render the grid ────────────────────────────────────
    function renderGrid() {
        const grid = document.getElementById('seatGrid');
        grid.innerHTML = '';
        const rows = isLuxury ? 10 : 10;
        const colsLeft = 2;
        const colsRight = isLuxury ? 1 : 2;

        for (let row = 1; row <= rows; row++) {
            // Left block
            for (let c = 0; c < colsLeft; c++) {
                const label = buildSeatLabel(row, c);
                grid.appendChild(createSeat(label));
            }
            // Aisle
            const aisle = document.createElement('div');
            aisle.className = 'seat-aisle';
            grid.appendChild(aisle);
            // Right block
            for (let c = colsLeft; c < colsLeft + colsRight; c++) {
                const label = buildSeatLabel(row, c);
                grid.appendChild(createSeat(label));
            }
        }
    }

    function createSeat(label) {
        const el = document.createElement('div');
        el.className = 'seat';
        el.textContent = label;
        el.dataset.seat = label;

        if (booked.has(label)) {
            el.classList.add('booked');
            el.title = 'Already booked';
        } else {
            el.addEventListener('click', () => toggleSeat(label, el));
        }
        return el;
    }

    function toggleSeat(label, el) {
        if (selected.has(label)) {
            selected.delete(label);
            el.classList.remove('selected');
        } else {
            if (selected.size >= maxSelect) {
                showToast(`You can select a maximum of ${maxSelect} seats.`, 'warning');
                return;
            }
            selected.add(label);
            el.classList.add('selected');
        }
        updateSummary();
    }

    function updateSummary() {
        const count = selected.size;
        const nums  = [...selected].sort().join(', ');

        document.getElementById('seatCount').textContent    = count;
        document.getElementById('seatNumbers').textContent  = count > 0 ? nums : '—';
        document.getElementById('hiddenSeatCount').value    = count;
        document.getElementById('hiddenSeatNumbers').value  = nums;

        const btn = document.getElementById('submitBtn');
        btn.disabled = count === 0;
        btn.style.opacity = count > 0 ? '1' : '0.5';
        btn.style.cursor  = count > 0 ? 'pointer' : 'not-allowed';

        // Chips
        const strip = document.getElementById('selectedStrip');
        const hint  = document.getElementById('emptyHint');
        // Remove old chips
        strip.querySelectorAll('.seat-chip').forEach(c => c.remove());

        if (count === 0) {
            hint.style.display = '';
        } else {
            hint.style.display = 'none';
            [...selected].sort().forEach(s => {
                const chip = document.createElement('span');
                chip.className = 'seat-chip';
                chip.textContent = s;
                strip.appendChild(chip);
            });
        }
    }

    function showToast(msg, type) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: type === 'warning' ? 'warning' : 'info',
                title: 'Notice',
                text: msg,
                background: '#151b23',
                color: '#f8fafc'
            });
        } else {
            alert(msg);
        }
    }

    // ── Fetch booked seats from API ────────────────────────
    async function loadBookedSeats() {
        if (!scheduleId) { renderGrid(); return; }
        try {
            const url = `/Customer/GetBookedSeats?scheduleId=${scheduleId}&travelDate=${travelDate}`;
            const res = await fetch(url);
            const data = await res.json();
            booked = new Set(data);
        } catch(e) {
            console.warn('Could not load booked seats', e);
        }
        renderGrid();
    }

    loadBookedSeats();
})();
</script>
}
