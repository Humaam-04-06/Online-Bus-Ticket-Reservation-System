@using Second_Try.Models
@model Employee
@{
    ViewData["Title"]      = "My Profile";
    ViewData["ActivePage"] = "EmployeeProfile";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
    string initials = string.Join("", Model.FullName.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));
}
@section Styles {
    <link rel="stylesheet" href="~/css/employee/emp-profile.css" asp-append-version="true" />
}
@if (TempData["SuccessMessage"] is string sm) {<div class="emp-toast emp-toast-success"><i class="fa-solid fa-circle-check"></i> @sm</div>}
@if (TempData["ErrorMessage"]   is string em) {<div class="emp-toast emp-toast-error"><i class="fa-solid fa-triangle-exclamation"></i> @em</div>}

<!-- ===== PROFILE HERO (Banner + Avatar) ===== -->
<div class="ep-hero-card">
    <!-- Banner -->
    <div class="ep-banner" id="ep-banner"
         style="@(!string.IsNullOrEmpty(Model.CoverPictureUrl) ? $"background-image:url('{Model.CoverPictureUrl}')" : "")">
        <form asp-controller="Employee" asp-action="UploadBanner" method="POST"
              enctype="multipart/form-data" id="banner-form">
            @Html.AntiForgeryToken()
            <label class="ep-banner-edit-btn" title="Change banner">
                <i class="fa-solid fa-image"></i> Change Banner
                <input type="file" name="banner" accept=".jpg,.jpeg,.png,.webp"
                       style="display:none;" onchange="document.getElementById('banner-form').submit();" />
            </label>
        </form>
    </div>

    <!-- Avatar + Info Row -->
    <div class="ep-hero-body">
        <div class="ep-avatar-wrapper">
            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" class="ep-avatar-img" alt="Profile" />
            }
            else
            {
                <div class="ep-avatar-initials">@initials</div>
            }
            <form asp-controller="Employee" asp-action="UploadPicture" method="POST"
                  enctype="multipart/form-data" id="pic-form">
                @Html.AntiForgeryToken()
                <label class="ep-avatar-edit-btn" title="Change photo">
                    <i class="fa-solid fa-camera"></i>
                    <input type="file" name="picture" accept=".jpg,.jpeg,.png,.webp"
                           style="display:none;" onchange="document.getElementById('pic-form').submit();" />
                </label>
            </form>
        </div>
        <div class="ep-hero-info">
            <h2 class="ep-hero-name">@Model.FullName</h2>
            <p class="ep-hero-email">@Model.Email</p>
            <span class="emp-badge @(Model.Role == EmployeeRole.Admin ? "emp-badge-admin" : "emp-badge-info")">
                @(Model.Role == EmployeeRole.Admin ? "Administrator" : "Standard Employee")
            </span>
        </div>
        <div class="ep-hero-meta">
            <span class="ep-meta-label">Member Since</span>
            <span class="ep-meta-val">@Model.CreatedAt.ToString("MMMM yyyy")</span>
        </div>
    </div>
</div>

<!-- ===== FORMS GRID ===== -->
<div class="ep-forms-grid">
    <!-- Update Info -->
    <div class="ep-form-card">
        <div class="ep-form-header"><i class="fa-solid fa-user-pen"></i> Update Profile</div>
        <form asp-controller="Employee" asp-action="UpdateEmployeeProfile" method="POST">
            @Html.AntiForgeryToken()
            <div class="ep-field">
                <label class="ep-label">Full Name</label>
                <input type="text" name="FullName" class="ep-input" value="@Model.FullName" required />
            </div>
            <div class="ep-field">
                <label class="ep-label">Email</label>
                <input type="email" class="ep-input" value="@Model.Email" disabled />
            </div>
            <div class="ep-field">
                <label class="ep-label">Role</label>
                <input type="text" class="ep-input" value="@Model.Role" disabled />
            </div>
            <button type="submit" class="emp-btn emp-btn-primary" style="width:100%;justify-content:center;">
                <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
        </form>
    </div>

    <!-- Change Password -->
    <div class="ep-form-card">
        <div class="ep-form-header"><i class="fa-solid fa-shield-halved"></i> Change Password</div>
        <form asp-controller="Employee" asp-action="ChangeEmployeePassword" method="POST">
            @Html.AntiForgeryToken()
            <div class="ep-field ep-pwd-field">
                <label class="ep-label">Current Password</label>
                <div class="ep-pwd-wrap">
                    <input type="password" name="CurrentPassword" class="ep-input" required id="ep-cur-pwd" />
                    <button type="button" class="ep-eye" onclick="togglePwd('ep-cur-pwd',this)"><i class="fa-solid fa-eye"></i></button>
                </div>
            </div>
            <div class="ep-field ep-pwd-field">
                <label class="ep-label">New Password</label>
                <div class="ep-pwd-wrap">
                    <input type="password" name="NewPassword" class="ep-input" required id="ep-new-pwd" minlength="8" oninput="checkStrength(this.value)" />
                    <button type="button" class="ep-eye" onclick="togglePwd('ep-new-pwd',this)"><i class="fa-solid fa-eye"></i></button>
                </div>
                <div class="ep-strength-bar"><div class="ep-strength-fill" id="ep-str-fill"></div></div>
                <div class="ep-strength-label" id="ep-str-label"></div>
            </div>
            <div class="ep-field ep-pwd-field">
                <label class="ep-label">Confirm Password</label>
                <div class="ep-pwd-wrap">
                    <input type="password" name="ConfirmPassword" class="ep-input" required id="ep-con-pwd" minlength="8" />
                    <button type="button" class="ep-eye" onclick="togglePwd('ep-con-pwd',this)"><i class="fa-solid fa-eye"></i></button>
                </div>
            </div>
            <button type="submit" class="emp-btn emp-btn-primary" style="width:100%;justify-content:center;">
                <i class="fa-solid fa-key"></i> Update Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd(id, btn) {
        const inp = document.getElementById(id);
        const isText = inp.type === 'text';
        inp.type = isText ? 'password' : 'text';
        btn.innerHTML = isText ? '<i class="fa-solid fa-eye"></i>' : '<i class="fa-solid fa-eye-slash"></i>';
    }
    function checkStrength(v) {
        const fill = document.getElementById('ep-str-fill');
        const label = document.getElementById('ep-str-label');
        let score = 0;
        if (v.length >= 8) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;
        const levels = ['','Weak','Fair','Good','Strong'];
        const colors = ['','#EF4444','#F59E0B','#3B82F6','#22C55E'];
        fill.style.width = (score * 25) + '%';
        fill.style.background = colors[score];
        label.textContent = levels[score];
        label.style.color = colors[score];
    }
</script>
}
