@using Second_Try.Models
@model BookingRequest
@{
    ViewData["Title"]      = "Process Request";
    ViewData["ActivePage"] = "BookingRequests";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";

    var buses    = ViewBag.AvailableBuses as List<Bus> ?? new List<Bus>();
    bool isPending = Model.Status == BookingRequestStatus.Pending;
    var booking   = Model.AssignedBooking;
}

@section Styles {
    <link rel="stylesheet" href="~/css/employee/process-request.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] is string sm)
{
    <div class="emp-toast emp-toast-success"><i class="fa-solid fa-circle-check"></i> @sm</div>
}
@if (TempData["ErrorMessage"] is string em)
{
    <div class="emp-toast emp-toast-error"><i class="fa-solid fa-triangle-exclamation"></i> @em</div>
}

<!-- Back + Title -->
<div class="pr-toprow">
    <a href="/Employee/BookingRequests" class="emp-btn emp-btn-outline emp-btn-sm">
        <i class="fa-solid fa-arrow-left"></i> Back to Requests
    </a>
    <div>
        <span class="pr-req-id">REQ-@Model.Id.ToString("D4")</span>
        @{
            string badgeCls = Model.Status switch
            {
                BookingRequestStatus.Pending   => "emp-badge-pending",
                BookingRequestStatus.Accepted  => "emp-badge-accepted",
                BookingRequestStatus.Rejected  => "emp-badge-rejected",
                BookingRequestStatus.Cancelled => "emp-badge-cancelled",
                _ => ""
            };
        }
        <span class="emp-badge @badgeCls">@Model.Status</span>
    </div>
</div>

<!-- Main 2-col grid -->
<div class="pr-grid">

    <!-- LEFT: Request Details -->
    <div>
        <!-- Customer Card -->
        <div class="emp-card pr-section">
            <div class="emp-card-header">
                <div class="emp-card-title"><i class="fa-solid fa-user"></i> Customer Details</div>
            </div>
            <div class="pr-info-rows">
                <div class="pr-info-row">
                    <span class="pr-info-label">Full Name</span>
                    <span class="pr-info-val">@(Model.Customer?.FullName ?? "—")</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Email</span>
                    <span class="pr-info-val">@(Model.Customer?.Email ?? "—")</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Phone</span>
                    <span class="pr-info-val">@(string.IsNullOrEmpty(Model.Customer?.PhoneNumber) ? "Not provided" : Model.Customer.PhoneNumber)</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Membership Tier</span>
                    <span class="pr-info-val">
                        @if (Model.Customer?.IsElite == true)
                        {
                            <span class="emp-badge" style="background:#E2E800; color:#141414; font-weight:800; border:none; box-shadow:0 0 10px rgba(226,232,0,0.5); display:inline-flex; align-items:center; gap:4px;">
                                <i class="fa-solid fa-crown" style="font-size:0.6rem;"></i> SRC ELITE
                            </span>
                        }
                        else
                        {
                            <span class="emp-badge emp-badge-outline" style="color:var(--text-muted); border-color:var(--border-color);">Standard Member</span>
                        }
                    </span>
                </div>
                @if (Model.Customer?.IsElite == true)
                {
                    <div class="pr-info-row">
                        <span class="pr-info-label">Loyalty Points</span>
                        <span class="pr-info-val" style="color:#E2E800; font-weight:700;">@Model.Customer.LoyaltyPoints pts</span>
                    </div>
                    var activeVouchers = ViewBag.ActiveVouchers as List<Voucher> ?? new List<Voucher>();
                    if (activeVouchers.Any())
                    {
                        <div class="pr-info-row" style="flex-direction:column; align-items:flex-start; gap:0.5rem; border-top:1px solid var(--border-color); padding-top:0.75rem; margin-top:0.25rem; width:100%;">
                            <span class="pr-info-label" style="font-size:0.75rem; color:#E2E800; display:block; margin-bottom:0.25rem;">Available Discount Vouchers</span>
                            <div style="width:100%; display:flex; flex-direction:column; gap:0.4rem;">
                                @foreach (var v in activeVouchers)
                                {
                                    <div style="background:#222222; border:1px solid #333333; border-radius:6px; padding:0.4rem 0.6rem; display:flex; justify-content:space-between; align-items:center; width:100%; box-sizing:border-box;">
                                        <span style="font-family:monospace; color:#E2E800; font-weight:700; font-size:0.8rem;">@v.Code</span>
                                        <span style="color:#10B981; font-weight:700; font-size:0.8rem;">- PKR @v.DiscountAmount</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Booking Request Card -->
        <div class="emp-card pr-section">
            <div class="emp-card-header">
                <div class="emp-card-title"><i class="fa-solid fa-ticket"></i> Booking Request Details</div>
            </div>
            <div class="pr-info-rows">
                <div class="pr-info-row">
                    <span class="pr-info-label">Origin</span>
                    <span class="pr-info-val">@(Model.Route?.Origin ?? "—")</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Destination</span>
                    <span class="pr-info-val">@(Model.Route?.Destination ?? "—")</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Travel Date</span>
                    <span class="pr-info-val">@Model.TravelDate.ToString("dddd, MMMM dd yyyy")</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Bus Class</span>
                    <span class="pr-info-val"><span class="emp-badge emp-badge-info">@Model.PreferredBusType</span></span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Seats Requested</span>
                    <span class="pr-info-val">@Model.NumberOfSeats</span>
                </div>
                <div class="pr-info-row">
                    <span class="pr-info-label">Request Date</span>
                    <span class="pr-info-val">@Model.RequestDate.ToString("MMM dd, yyyy · HH:mm") UTC</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.AdminRemarks))
                {
                    <div class="pr-info-row">
                        <span class="pr-info-label">Remarks</span>
                        <span class="pr-info-val pr-remarks">@Model.AdminRemarks</span>
                    </div>
                }
            </div>
        </div>

        <!-- Assigned Booking (if accepted) -->
        @if (booking != null)
        {
            <div class="emp-card pr-section pr-confirmed-card">
                <div class="emp-card-header">
                    <div class="emp-card-title"><i class="fa-solid fa-circle-check"></i> Confirmed Booking</div>
                    <a href="/Employee/PrintTicket/@booking.Id" class="emp-btn emp-btn-primary emp-btn-sm">
                        <i class="fa-solid fa-print"></i> Print Ticket
                    </a>
                </div>
                <div class="pr-info-rows">
                    <div class="pr-info-row">
                        <span class="pr-info-label">Bus</span>
                        <span class="pr-info-val">@(booking.Bus?.BusNumber ?? "—") (@(booking.Bus?.Type))</span>
                    </div>
                    <div class="pr-info-row">
                        <span class="pr-info-label">Seat Numbers</span>
                        <span class="pr-info-val">@booking.SeatNumbers</span>
                    </div>
                    <div class="pr-info-row">
                        <span class="pr-info-label">Total Fare</span>
                        <span class="pr-info-val pr-fare">PKR @booking.TotalFare.ToString("N0")</span>
                    </div>
                    <div class="pr-info-row">
                        <span class="pr-info-label">Confirmed At</span>
                        <span class="pr-info-val">@booking.ConfirmedAt.ToString("MMM dd, yyyy · HH:mm") UTC</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- RIGHT: Action Panel -->
    <div>
        @if (isPending)
        {
            <!-- Accept Form -->
            <div class="emp-card pr-section pr-accept-card">
                <div class="emp-card-header">
                    <div class="emp-card-title"><i class="fa-solid fa-circle-check"></i> Accept Request</div>
                </div>

                <form asp-controller="Employee" asp-action="AcceptRequest" method="POST" id="accept-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@Model.Id" />

                    <div class="pr-form-group">
                        <label class="pr-label">Assign Bus</label>
                        @if (buses.Any())
                        {
                            <select name="busId" class="pr-select" id="bus-select" required>
                                <option value="">— Select a Bus —</option>
                                @foreach (var bus in buses)
                                {
                                    <option value="@bus.Id" data-capacity="@bus.Capacity">
                                        @bus.BusNumber — @bus.Type (@bus.Capacity seats)
                                        @if (!string.IsNullOrEmpty(bus.Amenities))
                                        { <text>· @bus.Amenities</text> }
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <div class="pr-no-buses">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                No active @Model.PreferredBusType buses available. Please add buses first.
                            </div>
                        }
                    </div>

                    <div class="pr-form-group">
                        <label class="pr-label">Seat Numbers</label>
                        <input type="text" name="seatNumbers" class="pr-input" id="seat-numbers"
                               placeholder="e.g. 12A, 12B, 13A" required
                               value="@(string.IsNullOrEmpty(Model.SelectedSeatNumbers) ? "" : Model.SelectedSeatNumbers)"
                               title="Enter comma-separated seat numbers" />
                        <span class="pr-hint">Customer selected: @(string.IsNullOrEmpty(Model.SelectedSeatNumbers) ? "None" : Model.SelectedSeatNumbers)</span>
                    </div>

                    <!-- Applied Voucher (Read-Only) -->
                    <input type="hidden" name="appliedVoucherId" value="@Model.AppliedVoucherId" />
                    <div class="pr-form-group">
                        <label class="pr-label">Applied Discount Voucher</label>
                        @if (Model.AppliedVoucher != null)
                        {
                            <div style="background: rgba(226, 232, 0, 0.05); border: 1px solid rgba(226, 232, 0, 0.25); border-radius: 8px; padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.75rem; color: #E2E800; font-weight: 700; font-size: 0.9rem;">
                                <i class="fa-solid fa-ticket-simple" style="font-size: 1.1rem;"></i>
                                <span>@Model.AppliedVoucher.Code (PKR @Model.AppliedVoucher.DiscountAmount Off)</span>
                            </div>
                        }
                        else
                        {
                            <div style="background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.75rem 1rem; color: var(--text-muted); font-size: 0.875rem;">
                                <i class="fa-solid fa-ticket-simple" style="margin-right: 0.5rem; color: var(--text-muted);"></i> No Voucher Applied
                            </div>
                        }
                    </div>

                    <div class="pr-form-group">
                        <label class="pr-label">
                            Total Fare (PKR) 
                            @if (ViewBag.IsUsingFallbackFare == true)
                            {
                                <span style="font-size:0.75rem; color:#EF4444; font-weight:normal; margin-left:0.5rem;">
                                    (Estimated base: PKR @(((decimal)ViewBag.BaseFarePerSeat).ToString("N0"))/seat)
                                </span>
                            }
                            else
                            {
                                <span style="font-size:0.75rem; color:var(--text-muted); font-weight:normal; margin-left:0.5rem;">
                                    (Base: PKR @(((decimal)ViewBag.BaseFarePerSeat).ToString("N0"))/seat)
                                </span>
                            }
                        </label>
                        <input type="number" name="totalFare" id="total-fare" class="pr-input"
                               style="background-color: #1a1a1a; color: #a0a0a0; cursor: not-allowed;"
                               min="0.01" step="0.01" placeholder="e.g. 2500" required readonly
                               value="@(ViewBag.CalculatedFare != null && ViewBag.CalculatedFare > 0 ? ViewBag.CalculatedFare : "")" />
                        <span class="pr-hint" id="fare-calc-hint" style="margin-top:0.4rem; display:block; font-size:0.75rem; color:var(--text-muted);">
                            Calculation: <span id="hint-seat-count">@Model.NumberOfSeats</span> seat(s) &times; PKR @(((decimal)ViewBag.BaseFarePerSeat).ToString("N0")) 
                            <span id="hint-discount-section" style="display:none;"> - PKR <span id="hint-discount-val">0</span> (Voucher)</span>
                        </span>
                    </div>

                    <button type="submit" class="emp-btn emp-btn-success pr-submit-btn" @(buses.Any() ? "" : "disabled")>
                        <i class="fa-solid fa-circle-check"></i> Confirm & Accept
                    </button>
                </form>
            </div>

            <!-- Reject Form -->
            <div class="emp-card pr-section pr-reject-card">
                <div class="emp-card-header">
                    <div class="emp-card-title"><i class="fa-solid fa-circle-xmark"></i> Reject Request</div>
                </div>

                <form asp-controller="Employee" asp-action="RejectRequest" method="POST" onsubmit="return confirm('Are you sure you want to reject this request?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@Model.Id" />

                    <div class="pr-form-group">
                        <label class="pr-label">Rejection Reason</label>
                        <textarea name="remarks" class="pr-textarea" rows="3"
                                  placeholder="e.g. No available bus on requested date..." required></textarea>
                    </div>

                    <button type="submit" class="emp-btn emp-btn-danger pr-submit-btn">
                        <i class="fa-solid fa-circle-xmark"></i> Reject Request
                    </button>
                </form>
            </div>
        }
        else
        {
            <!-- Already processed -->
            <div class="emp-card pr-section pr-processed-card">
                <div class="emp-card-title" style="margin-bottom:1rem;">
                    <i class="fa-solid fa-lock"></i> Request Already Processed
                </div>
                <p class="pr-processed-msg">
                    This request was <strong>@Model.Status.ToString().ToLower()</strong> and cannot be modified.
                </p>
                @if (booking != null)
                {
                    <a href="/Employee/PrintTicket/@booking.Id" class="emp-btn emp-btn-outline" style="margin-top:1rem;width:100%;justify-content:center;">
                        <i class="fa-solid fa-print"></i> Print Ticket
                    </a>
                }
                <a href="/Employee/BookingRequests" class="emp-btn emp-btn-outline" style="margin-top:0.5rem;width:100%;justify-content:center;">
                    <i class="fa-solid fa-arrow-left"></i> Back to Requests
                </a>
            </div>

            @if (Model.Status == BookingRequestStatus.Accepted)
            {
                <div class="emp-card pr-section pr-completed-card" style="margin-top:1.5rem;">
                    <div class="emp-card-header">
                        <div class="emp-card-title"><i class="fa-solid fa-flag-checkered"></i> Complete Trip</div>
                    </div>
                    <div style="padding:1.25rem;">
                        <p style="color:var(--text-muted);font-size:0.875rem;margin-bottom:1rem;">
                            Marking this request as Completed means the passenger has boarded. This allows the customer to leave a review.
                        </p>
                        <form asp-controller="Employee" asp-action="MarkCompleted" method="POST">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@Model.Id" />
                            <button type="submit" class="emp-btn emp-btn-primary" style="width:100%;justify-content:center;background:linear-gradient(135deg,var(--accent-cyan),#007BFF);color:#000;">
                                <i class="fa-solid fa-flag-checkered"></i> Mark as Completed
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

</div>

@section Scripts {
<script>
    // Auto-calculate fare based on seat count and voucher discount
    const fareInput  = document.getElementById('total-fare');
    const seatInput = document.getElementById('seat-numbers');

    const baseFarePerSeat = parseFloat('@(ViewBag.BaseFarePerSeat ?? 0)');
    const discount = parseFloat('@(Model.AppliedVoucher?.DiscountAmount ?? 0)');

    function calculateTotalFare() {
        if (!fareInput) return;

        // 1. Calculate seats from comma-separated input
        const seatVal = seatInput?.value || '';
        const seats = seatVal.split(',').map(s => s.trim()).filter(s => s.length > 0);
        const seatCount = seats.length;

        // 2. Subtotal
        const subtotal = seatCount * baseFarePerSeat;

        // 3. Final Fare
        const finalFare = Math.max(0, subtotal - discount);
        fareInput.value = finalFare.toFixed(2);

        // 4. Update UI Hint
        const hintSeatCount = document.getElementById('hint-seat-count');
        const hintDiscountSection = document.getElementById('hint-discount-section');
        const hintDiscountVal = document.getElementById('hint-discount-val');

        if (hintSeatCount) hintSeatCount.textContent = seatCount;
        if (hintDiscountSection && hintDiscountVal) {
            if (discount > 0 && seatCount > 0) {
                hintDiscountVal.textContent = discount.toLocaleString();
                hintDiscountSection.style.display = 'inline';
            } else {
                hintDiscountSection.style.display = 'none';
            }
        }
    }

    // Attach listeners
    seatInput?.addEventListener('input', calculateTotalFare);

    // Initial calculation on load
    calculateTotalFare();

    document.addEventListener('DOMContentLoaded', () => {
        const acceptForm = document.getElementById('accept-form');
        acceptForm?.addEventListener('submit', function(e) {
            const busVal = document.getElementById('bus-select')?.value;
            const seatVal = document.getElementById('seat-numbers')?.value;
            const fareVal = parseFloat(document.getElementById('total-fare')?.value || '0');

            if (!busVal) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation Error',
                    text: 'Please select a bus to assign.',
                    background: '#222222',
                    color: '#F3F4F6',
                    confirmButtonColor: '#E2E800'
                });
                return;
            }

            if (!seatVal || !seatVal.trim()) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation Error',
                    text: 'Please enter seat numbers.',
                    background: '#222222',
                    color: '#F3F4F6',
                    confirmButtonColor: '#E2E800'
                });
                return;
            }

            if (isNaN(fareVal) || fareVal <= 0) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Validation Error',
                    text: 'Total fare must be greater than zero.',
                    background: '#222222',
                    color: '#F3F4F6',
                    confirmButtonColor: '#E2E800'
                });
                return;
            }
        });
    });
</script>
}
