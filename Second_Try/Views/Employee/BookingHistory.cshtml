@using Second_Try.Models
@{
    ViewData["Title"]      = "Booking History";
    ViewData["ActivePage"] = "BookingHistory";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";

    var bookings    = ViewBag.Bookings as List<Booking> ?? new List<Booking>();
    string currSearch = ViewBag.Search ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/employee/emp-booking-requests.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] is string sm)
{
    <div class="emp-toast emp-toast-success"><i class="fa-solid fa-circle-check"></i> @sm</div>
}

<!-- Page Header -->
<div class="emp-page-header" style="display:flex; justify-content:space-between; align-items:center;">
    <div>
        <h2 class="emp-page-heading">Booking History</h2>
        <p class="emp-page-sub">All confirmed and completed bookings. Total: <strong>@bookings.Count</strong></p>
    </div>
    <div style="display:flex; gap:10px; align-items:center;">
        <button id="btn-download-pdf" class="emp-btn emp-btn-success" style="height: 42px; border-radius: 8px; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 8px;"><i class="fa-solid fa-file-pdf"></i> Download PDF</button>
        <div class="emp-search-wrapper" style="margin: 0;">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="hist-search" class="emp-search-input"
                   placeholder="Search customer or bus..." value="@currSearch" />
        </div>
    </div>
</div>

<!-- Table -->
<div class="emp-card">
    @if (bookings.Any())
    {
        <div class="emp-table-wrapper">
            <table class="emp-table" id="history-table">
                <thead>
                    <tr>
                        <th>Booking #</th>
                        <th>Customer</th>
                        <th>Route</th>
                        <th>Travel Date</th>
                        <th>Bus</th>
                        <th>Seats</th>
                        <th>Total Fare</th>
                        <th>Status</th>
                        <th>Confirmed</th>
                        <th>Ticket</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in bookings)
                    {
                        string bStatusCls = b.Status switch
                        {
                            BookingStatus.Confirmed => "emp-badge-accepted",
                            BookingStatus.Completed => "emp-badge-info",
                            BookingStatus.Cancelled => "emp-badge-cancelled",
                            _ => ""
                        };

                        string custName = b.BookingRequest?.Customer?.FullName ?? "—";
                        string custInit = string.Join("", custName.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));

                        <tr class="hist-row" data-search="@custName @(b.Bus?.BusNumber ?? "") @b.SeatNumbers">
                            <td><span class="emp-req-id">BK-@b.Id.ToString("D4")</span></td>
                            <td>
                                <div class="emp-customer-cell">
                                    <div class="emp-customer-avatar">@custInit</div>
                                    <div>
                                        <div class="emp-customer-name">@custName</div>
                                        <div class="emp-customer-email">REQ-@(b.BookingRequestId.ToString("D4"))</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="emp-route-cell">
                                    @(b.BookingRequest?.Route?.Origin ?? "—")
                                    <i class="fa-solid fa-arrow-right" style="font-size:0.6rem;"></i>
                                    @(b.BookingRequest?.Route?.Destination ?? "—")
                                </span>
                            </td>
                            <td class="muted">@(b.BookingRequest?.TravelDate.ToString("MMM dd, yyyy") ?? "—")</td>
                            <td class="muted">@(b.Bus?.BusNumber ?? "—") <span class="emp-badge emp-badge-info" style="font-size:0.62rem;">@(b.Bus?.Type)</span></td>
                            <td class="muted">@b.SeatNumbers</td>
                            <td style="font-weight:700;color:var(--emp-accepted-color);">PKR @b.TotalFare.ToString("N0")</td>
                            <td><span class="emp-badge @bStatusCls">@b.Status</span></td>
                            <td class="muted">@b.ConfirmedAt.ToString("MMM dd, yy")</td>
                            <td>
                                <a href="/Employee/PrintTicket/@b.Id" class="emp-btn emp-btn-primary emp-btn-sm">
                                    <i class="fa-solid fa-print"></i> Print
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="emp-empty-state">
            <div class="emp-empty-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
            <p class="emp-empty-title">No Booking History</p>
            <p class="emp-empty-sub">Confirmed bookings will appear here once requests are accepted.</p>
        </div>
    }
</div>

@section Scripts {
<script>
    document.getElementById('hist-search')?.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.hist-row').forEach(row => {
            row.style.display = (row.dataset.search ?? '').toLowerCase().includes(q) ? '' : 'none';
        });
    });

    document.getElementById('btn-download-pdf')?.addEventListener('click', function() {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });

        // Draw header/title block
        doc.setFillColor(31, 41, 55); // dark gray employee theme color
        doc.rect(0, 0, 297, 40, 'F');

        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(22);
        doc.text('SRC TRAVEL SYSTEM', 14, 18);
        
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(12);
        doc.setTextColor(200, 200, 200);
        doc.text('Booking History Report', 14, 25);
        doc.text('Role: Employee | Date: ' + new Date().toLocaleDateString() + ' ' + new Date().toLocaleTimeString(), 14, 32);

        // AutoTable headers & body
        const headers = [['BK #', 'Customer Name', 'Request ID', 'Route', 'Travel Date', 'Bus', 'Seats', 'Fare (PKR)', 'Status', 'Confirmed At']];
        const body = [];
        
        // We only include visible rows!
        const rows = document.querySelectorAll('#history-table tbody tr');
        rows.forEach(row => {
            if (row.style.display !== 'none') {
                const bkNum = row.cells[0].innerText.trim();
                
                // Name + request ID are inside the Customer cell
                const nameEl = row.querySelector('.emp-customer-name');
                const emailEl = row.querySelector('.emp-customer-email');
                const custName = nameEl ? nameEl.innerText.trim() : '';
                const reqId = emailEl ? emailEl.innerText.trim() : '';
                
                const route = row.cells[2].innerText.trim();
                const travelDate = row.cells[3].innerText.trim();
                const bus = row.cells[4].innerText.trim().replace(/\n/g, ' ');
                const seats = row.cells[5].innerText.trim();
                const fare = row.cells[6].innerText.trim();
                const status = row.cells[7].innerText.trim();
                const confirmed = row.cells[8].innerText.trim();
                
                body.push([bkNum, custName, reqId, route, travelDate, bus, seats, fare, status, confirmed]);
            }
        });

        doc.autoTable({
            head: headers,
            body: body,
            startY: 45,
            theme: 'striped',
            headStyles: {
                fillColor: [31, 41, 55],
                textColor: [255, 255, 255],
                fontStyle: 'bold'
            },
            alternateRowStyles: {
                fillColor: [240, 243, 246]
            },
            styles: {
                fontSize: 9,
                cellPadding: 3
            },
            columnStyles: {
                0: { cellWidth: 20 },
                1: { cellWidth: 40 },
                2: { cellWidth: 22 },
                3: { cellWidth: 45 },
                4: { cellWidth: 25 },
                5: { cellWidth: 35 },
                6: { cellWidth: 20 },
                7: { cellWidth: 22 },
                8: { cellWidth: 25 },
                9: { cellWidth: 25 }
            }
        });

        doc.save('SRCTravel_Booking_History.pdf');
    });
</script>
}
